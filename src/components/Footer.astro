---
import { targetCities } from "../data/seo-pages";

const {
  home = false,
  i18n = false
} = Astro.props;

const attr = (key: string) => (i18n ? { "data-i18n": key } : {});
const navLinks = [
  ["Tentang", "/#about", "nav.about"],
  ["Layanan", "/#services", "nav.services"],
  ["Harga", "/#pricing", "nav.pricing"],
  ["Karya", "/project", "nav.work"],
  ["Proses", "/#process", "nav.process"]
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <h2 {...attr("footer.title")}>Bangun sesuatu yang orang ingat.</h2>
      {home ? (
        <button class="btn-primary" type="button" data-scroll="contact">
          <span {...attr("footer.cta")}>Mulai Proyek</span>
          <svg class="arrow" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg>
        </button>
      ) : (
        <button class="btn-primary" type="button" data-home-contact>
          <span {...attr("footer.cta")}>Mulai Proyek</span>
          <svg class="arrow" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg>
        </button>
      )}
    </div>

    <div class="footer-grid">
      <div class="footer-col footer-brand-col">
        <span class="brand">
          <img src="/solivate-logo.webp" alt="Solivate Studio" width="166" height="20" loading="lazy" />
        </span>
        <p {...attr("footer.desc")}>Digital solution provider untuk UMKM, komunitas sosial, event, celebration, dan sistem custom yang ingin naik kelas secara digital.</p>
        <p class="footer-location">Bekasi, Indonesia</p>
      </div>
      <div class="footer-col">
        <h4 {...attr("footer.nav")}>Navigasi</h4>
        {navLinks.map(([label, href, key]) => (
          <a href={home && href.startsWith("/#") ? href.replace("/#", "#") : href} {...attr(key)}>{label}</a>
        ))}
      </div>
      <div class="footer-col">
        <h4 data-i18n="footer.legal">Kebijakan</h4>
        <a href="/privacy-policy" data-i18n="footer.privacy">Kebijakan Privasi</a>
        <a href="/terms" data-i18n="footer.terms">Syarat & Ketentuan</a>
        <a href="/revision-policy" data-i18n="footer.revision">Kebijakan Revisi</a>
      </div>
      <div class="footer-col">
        <h4 {...attr("footer.connect")}>Kontak</h4>
        <a href="#" data-email-obfuscated class="footer-email-link">solivatestudio [at] gmail.com</a>
        <a href="https://wa.me/6281219118993" target="_blank" rel="noreferrer">WhatsApp</a>
        <a href="https://www.instagram.com/solivatestudio/" target="_blank" rel="noreferrer">Instagram</a>
      </div>
    </div>

    <div class="footer-local-cloud">
      <h4>Wilayah Layanan</h4>
      <div class="local-links">
        {targetCities.map((city) => (
          <a href={`/jasa-pembuatan-website-${city.slug}`}>Jasa Website {city.name}</a>
        ))}
      </div>
    </div>

    <div class="footer-bottom">
      <span {...attr("footer.copy")}>Copyright {new Date().getFullYear()} Solivate Studio. Semua hak dilindungi.</span>
      <button class="footer-top-btn" type="button" data-top>
        <span {...attr("footer.top")}>Kembali ke atas</span>
        <svg class="arrow" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg>
      </button>
    </div>
  </div>
</footer>

<a
  class="floating-wa"
  href="https://wa.me/6281219118993?text=Halo%20Solivate%20Studio%2C%20saya%20mau%20konsultasi%20gratis%20untuk%20project%20website."
  target="_blank"
  rel="noreferrer"
  aria-label="Konsultasi sekarang, gratis via WhatsApp"
>
  <span class="floating-wa-pulse" aria-hidden="true"></span>
  <span class="floating-wa-icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="currentColor">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347M12.051 21.785h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.999-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.889-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.887 9.884M20.463 3.488A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.946L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"></path>
    </svg>
  </span>
  <span class="floating-wa-label" {...attr("floating.wa")}>Konsultasi sekarang, gratis!</span>
</a>

<script is:inline>
  document.querySelectorAll("[data-email-obfuscated]").forEach((el) => {
    const user = "solivatestudio";
    const domain = "gmail.com";
    const email = `${user}@${domain}`;
    el.addEventListener("click", (e) => {
      e.preventDefault();
      window.location.href = `mailto:${email}`;
    });
    el.addEventListener("mouseover", () => {
      el.setAttribute("href", `mailto:${email}`);
      el.textContent = email;
    });
  });
</script>
