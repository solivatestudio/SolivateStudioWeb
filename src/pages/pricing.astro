              <svg class="arrow" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg>
            </a>
          </div>
        </div>
      </section>

      <section class="section light">
        <div class="container section-head split">
          <div>
            <p class="eyebrow" data-i18n="personal.eyebrow">{tx("personal.eyebrow")}</p>
            <h2 data-i18n="personal.title">{tx("personal.title")}</h2>
          </div>
          <p class="lead" data-i18n="personal.lead">{tx("personal.lead")}</p>
        </div>
        <div class="container pricing-detail-grid compact">
          {personalPlans.map((plan, planIndex) => (
            <article class="pricing-detail-card">
              <span class="pricing-label" data-i18n="label.personal">{tx("label.personal")}</span>
              <h3>{plan.name}</h3>
              <strong>{plan.price}</strong>
              <p data-i18n={`personal.${planIndex}.fit`}>{tx(`personal.${planIndex}.fit`)}</p>
              <ul>
                {plan.items.map((item, itemIndex) => <li data-i18n={`personal.${planIndex}.item.${itemIndex}`}>{item}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section class="section pricing-detail-band">
        <div class="container section-head split">
          <div>
            <p class="eyebrow" data-i18n="business.eyebrow">{tx("business.eyebrow")}</p>
            <h2 data-i18n="business.title">{tx("business.title")}</h2>
          </div>
          <p class="lead" data-i18n="business.lead">{tx("business.lead")}</p>
        </div>
        <div class="container pricing-detail-grid">
          {businessPlans.map((plan, planIndex) => (
            <article class={`pricing-detail-card business ${plan.featured ? "featured" : ""}`}>
              <span class="pricing-label" data-i18n={`business.${planIndex}.badge`}>{tx(`business.${planIndex}.badge`)}</span>
              <h3>{plan.name}</h3>
              <strong>{plan.price}</strong>
              <p data-i18n={`business.${planIndex}.note`}>{tx(`business.${planIndex}.note`)}</p>
              <ul>
                {plan.items.map((item, itemIndex) => <li data-i18n={`business.${planIndex}.item.${itemIndex}`}>{item}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section class="section light comparison-section">
        <div class="container section-head">
          <p class="eyebrow" data-i18n="comparison.eyebrow">{tx("comparison.eyebrow")}</p>
          <h2 data-i18n="comparison.title">{tx("comparison.title")}</h2>
        </div>
        <div class="container comparison-shell">
          <table class="comparison-table">
            <thead>
              <tr>
                <th><span class="comparison-plan-title" data-i18n="compare.feature">{tx("compare.feature")}</span></th>
                <th>
                  <span class="comparison-plan-title" data-i18n="compare.plan1">{tx("compare.plan1")}</span>
                  <span class="comparison-plan-badge" data-i18n="compare.basic">{tx("compare.basic")}</span>
                </th>
                <th>
                  <span class="comparison-plan-title" data-i18n="compare.plan2">{tx("compare.plan2")}</span>
                  <span class="comparison-plan-badge" data-i18n="compare.standard">{tx("compare.standard")}</span>
                </th>
                <th>
                  <span class="comparison-plan-title" data-i18n="compare.plan3">{tx("compare.plan3")}</span>
                  <span class="comparison-plan-badge" data-i18n="compare.premium">{tx("compare.premium")}</span>
                </th>
              </tr>
            </thead>
            <tbody>
              {comparisonRows.map((row, rowIndex) => (
                <tr>
                  <th data-i18n={comparisonFeatureKeys[rowIndex]}>{tx(comparisonFeatureKeys[rowIndex])}</th>
                  {planKeys.map((plan, planIndex) => (
                    <td>
                      <span class={`comparison-cell ${row[plan].type}`}>
                        <span class="comparison-icon" aria-hidden="true"></span>
                        <span data-i18n={comparisonValueKeys[rowIndex][planIndex] || undefined}>{comparisonValueKeys[rowIndex][planIndex] ? tx(comparisonValueKeys[rowIndex][planIndex]) : row[plan].label}</span>
                      </span>
                    </td>
                  ))}
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>

      <section class="section dark custom-pricing">
        <div class="container custom-pricing-grid">
          <div>
            <p class="eyebrow" data-i18n="custom.eyebrow">{tx("custom.eyebrow")}</p>
            <h2 data-i18n="custom.title">{tx("custom.title")}</h2>
            <p class="lead" data-i18n="custom.lead">{tx("custom.lead")}</p>
          </div>
          <div class="custom-price-box">
            <span data-i18n="custom.priceLabel">{tx("custom.priceLabel")}</span>
            <strong>Rp 2.999.000</strong>
            <p data-i18n="custom.priceNote">{tx("custom.priceNote")}</p>
          </div>
        </div>
        <div class="container custom-feature-grid">
          {customFeatures.map((_, index) => (
            <article>
              <span></span>
              <p data-i18n={`custom.feature.${index}`}>{tx(`custom.feature.${index}`)}</p>
            </article>
          ))}
        </div>
      </section>
    </main>

    <Footer i18n />

    <script is:inline type="application/ld+json" set:html={pricingSchema}></script>
    <script is:inline type="application/json" id="pricing-i18n-data" set:html={pricingI18nJson}></script>
    <script is:inline>
      const translations = JSON.parse(document.getElementById("pricing-i18n-data")?.textContent || "{}");
      const header = document.querySelector("[data-header]");
      let cmsResources = {};
      const escapeHtml = (value) => String(value ?? "").replace(/[&<>"']/g, (char) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        "\"": "&quot;",
        "'": "&#039;"
      }[char]));
      const cmsText = (data, key, lang) => data?.[`${key}_${lang}`] || data?.[`${key}_id`] || data?.[key] || "";
      const cmsList = (data, key, lang) => Array.isArray(data?.[`${key}_${lang}`]) ? data[`${key}_${lang}`] : [];
      const pricingCard = (item, lang) => {
        const data = item.data || {};
        const features = cmsList(data, "features", lang);
        return `<article class="pricing-detail-card ${data.group === "business" ? "business" : ""} ${data.featured ? "featured" : ""}">
          <span class="pricing-label">${escapeHtml(cmsText(data, "badge", lang))}</span>
          <h3>${escapeHtml(cmsText(data, "name", lang))}</h3>
          <strong>${escapeHtml(cmsText(data, "price", lang))}</strong>
          <p>${escapeHtml(cmsText(data, "description", lang))}</p>
          <ul>${features.map((feature) => `<li>${escapeHtml(feature)}</li>`).join("")}</ul>
        </article>`;
      };
      const renderCmsPricing = (lang = document.documentElement.lang || "id") => {
        const activeLang = lang === "en" ? "en" : "id";
        const pricing = cmsResources.pricing || [];
        const personal = pricing.filter((item) => item.data?.group === "personal");
        const business = pricing.filter((item) => item.data?.group === "business");
        const custom = pricing.find((item) => item.data?.group === "custom");
        const personalGrid = document.querySelector(".pricing-detail-grid.compact");
        const businessGrid = document.querySelector(".pricing-detail-band .pricing-detail-grid");
        if (personalGrid && personal.length) personalGrid.innerHTML = personal.map((item) => pricingCard(item, activeLang)).join("");
        if (businessGrid && business.length) businessGrid.innerHTML = business.map((item) => pricingCard(item, activeLang)).join("");
        if (custom) {
          const data = custom.data || {};
          const priceBox = document.querySelector(".custom-price-box");
          const featureGrid = document.querySelector(".custom-feature-grid");
          const customTitle = document.querySelector(".custom-pricing h2");
          if (customTitle) customTitle.textContent = cmsText(data, "name", activeLang);
          if (priceBox) {
            priceBox.innerHTML = `<span>${activeLang === "en" ? "Starting price" : "Harga mulai dari"}</span><strong>${escapeHtml(cmsText(data, "price", activeLang))}</strong><p>${escapeHtml(cmsText(data, "description", activeLang))}</p>`;
          }
          if (featureGrid) {
            featureGrid.innerHTML = cmsList(data, "features", activeLang).map((feature) => `<article><span></span><p>${escapeHtml(feature)}</p></article>`).join("");
          }
        }
      };
      const updateHeader = () => {
        const y = Math.max(0, window.scrollY);
        header?.classList.toggle("is-scrolled", y > 24);
        header?.classList.toggle("is-compact", y > 64);
      };
      window.addEventListener("scroll", updateHeader, { passive: true });
      updateHeader();

      const setLanguage = (lang, persist = false) => {
        const activeLang = lang === "en" ? "en" : "id";
        document.documentElement.lang = activeLang;
        if (persist) {
          window.localStorage.setItem("solivate-language", activeLang);
          window.localStorage.setItem("solivate-language-manual", "true");
        }

        document.querySelectorAll("[data-i18n]").forEach((node) => {
          const key = node.getAttribute("data-i18n");
          const next = translations[key]?.[activeLang];
          if (next) node.textContent = next;
        });

        document.querySelectorAll("[data-lang-switch]").forEach((button) => {
          const active = button.getAttribute("data-lang-switch") === activeLang;
          button.classList.toggle("active", active);
          button.setAttribute("aria-pressed", String(active));
        });
        renderCmsPricing(activeLang);
      };

      document.querySelectorAll("[data-lang-switch]").forEach((button) => {
        button.addEventListener("click", () => setLanguage(button.getAttribute("data-lang-switch"), true));
      });
      const savedLanguage = window.localStorage.getItem("solivate-language-manual") === "true"
        ? window.localStorage.getItem("solivate-language")
        : "id";
      setLanguage(savedLanguage || "id");

      fetch("/api/public/content?type=pricing", { cache: "no-store" })
        .then((response) => response.ok ? response.json() : null)
        .then((data) => {
          cmsResources = data?.resources || {};
          renderCmsPricing(document.documentElement.lang);
        })
        .catch(() => {});

      fetch("/api/public/cms", { cache: "no-store" })
        .then((response) => response.ok ? response.json() : null)
        .then((data) => {
          const whatsapp = String(data?.entries?.contact_whatsapp || "").replace(/\D/g, "");
          if (!whatsapp) return;
          const text = encodeURIComponent("Halo Solivate Studio, saya mau konsultasi gratis untuk project website.");
          document.querySelectorAll("[data-whatsapp-cta]").forEach((node) => {
            node.href = `https://wa.me/${whatsapp}?text=${text}`;
          });
        })
        .catch(() => {});

      document.querySelectorAll("[data-top]").forEach((trigger) => {
        trigger.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
      });

      document.querySelectorAll("[data-home-contact]").forEach((trigger) => {
        trigger.addEventListener("click", () => {
          window.location.href = "/#contact";
        });
      });

      if (!window.matchMedia("(hover: none)").matches) {
        document.querySelectorAll(".btn-primary, .nav-cta, .pricing-detail-card, .custom-feature-grid article").forEach((el) => {
          let frame = 0;
          const strength = el.matches(".btn-primary, .nav-cta") ? 0.12 : 0.035;
          el.addEventListener("mousemove", (event) => {
            const pointer = event;
            window.cancelAnimationFrame(frame);
            frame = window.requestAnimationFrame(() => {
              const rect = el.getBoundingClientRect();
              const x = (pointer.clientX - (rect.left + rect.width / 2)) * strength;
              const y = (pointer.clientY - (rect.top + rect.height / 2)) * strength;
              el.style.setProperty("--hover-x", `${x.toFixed(2)}px`);
              el.style.setProperty("--hover-y", `${y.toFixed(2)}px`);
            });
          });
          el.addEventListener("mouseleave", () => {
            window.cancelAnimationFrame(frame);
            el.style.setProperty("--hover-x", "0px");
            el.style.setProperty("--hover-y", "0px");
          });
        });
      }
    </script>
  </body>
</html>
