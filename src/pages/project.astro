---
import "../index.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { siteUrl } from "../data/seo-pages";

type LocaleCopy = {
  id: string;
  en: string;
};

const projectI18n: Record<string, LocaleCopy> = {
  "meta.description": {
    id: "Showcase portfolio & project Solivate Studio: website masjid, barbershop booking online, bakery UMKM, komunitas, yayasan, undangan pernikahan digital, dan sistem custom.",
    en: "Solivate Studio portfolio showcase: mosque, barbershop online booking, bakery SME, community, foundation, digital wedding invitation, and custom systems."
  },
  "nav.about": { id: "Tentang", en: "About" },
  "nav.services": { id: "Layanan", en: "Services" },
  "nav.pricing": { id: "Harga", en: "Pricing" },
  "nav.work": { id: "Karya", en: "Work" },
  "nav.process": { id: "Proses", en: "Process" },
  "nav.contact": { id: "Kontak", en: "Contact" },
  "nav.cta": { id: "Mulai Proyek", en: "Start Project" },
  "project.eyebrow": { id: "Project Showcase", en: "Project Showcase" },
  "project.title": {
    id: "Karya digital yang dibangun untuk kebutuhan nyata.",
    en: "Digital work built for real needs."
  },
  "project.lead": {
    id: "Lihat bagaimana Solivate Studio membantu komunitas, UMKM, dan brand lokal punya website yang rapi, cepat, dan siap dipakai.",
    en: "See how Solivate Studio helps communities, SMEs, and local brands own clean, fast, and launch-ready websites."
  },
  "project.stat.1.label": { id: "Project aktif", en: "Active projects" },
  "project.stat.2.label": { id: "Target pasar", en: "Target markets" },
  "project.stat.3.label": { id: "Fokus utama", en: "Main focus" },
  "project.stat.3.value": { id: "Website cepat", en: "Fast websites" },
  "project.list.eyebrow": { id: "Selected Work", en: "Selected Work" },
  "project.list.title": {
    id: "Showcase website Solivate Studio.",
    en: "Solivate Studio website showcase."
  },
  "project.case": { id: "Lihat Project", en: "View Project" },
  "project.live": { id: "Kunjungi Website", en: "Visit Website" },
  "project.empty": {
    id: "Belum ada project yang dipublikasikan dari dashboard CMS.",
    en: "No published projects yet from the CMS dashboard."
  },
  "project.cta.eyebrow": { id: "Mau project seperti ini?", en: "Want a project like this?" },
  "project.cta.title": {
    id: "Konsultasi sekarang, gratis. Kita susun scope yang paling masuk akal untuk brand Anda.",
    en: "Get a free consultation. We will shape a practical scope for your brand."
  },
  "project.cta.button": { id: "Mulai Konsultasi", en: "Start Consultation" },
  "footer.title": { id: "Bangun sesuatu yang orang ingat.", en: "Let's build something people remember." },
  "footer.cta": { id: "Mulai Proyek", en: "Start Project" },
  "footer.desc": {
    id: "Digital solution provider untuk UMKM, komunitas sosial, event, celebration, dan sistem custom yang ingin naik kelas secara digital.",
    en: "Digital solution provider for SMEs, social communities, events, celebrations, and custom systems ready to level up digitally."
  },
  "footer.nav": { id: "Navigasi", en: "Navigation" },
  "footer.connect": { id: "Kontak", en: "Connect" },
  "footer.legal": { id: "Kebijakan", en: "Policies" },
  "footer.privacy": { id: "Kebijakan Privasi", en: "Privacy Policy" },
  "footer.terms": { id: "Syarat & Ketentuan", en: "Terms & Conditions" },
  "footer.revision": { id: "Kebijakan Revisi", en: "Revision Policy" },
  "footer.copy": { id: `Copyright ${new Date().getFullYear()} Solivate Studio. Semua hak dilindungi.`, en: `Copyright ${new Date().getFullYear()} Solivate Studio. All rights reserved.` },
  "footer.top": { id: "Kembali ke atas", en: "Back to top" },
  "floating.wa": { id: "Konsultasi sekarang, gratis!", en: "Free consultation now!" }
};

const i18nJson = JSON.stringify(projectI18n);
const pageTitle = "Project Showcase Solivate Studio | Website UMKM, Komunitas & Digital solution agency Indonesia";
const pageDescription = projectI18n["meta.description"].id;
const canonical = `${siteUrl}/project`;
const heroImage = "/solivate-logo.webp";
const collectionSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: "Project Showcase Solivate Studio",
  url: canonical,
  description: pageDescription
});
const gaId = import.meta.env.PUBLIC_GA_ID || "G-H1R8S8W5W6";
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content="project Solivate Studio, portfolio Solivate Studio, website UMKM, website barbershop, website bakery, website masjid, jasa pembuatan website, digital solution provider Indonesia, jasa pembuatan website Solivate Studio, digital solution agency Indonesia, jasa digitalisasi UMKM" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Solivate Studio" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${siteUrl}${heroImage}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    {gaId && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
  </head>
  <body>
    <Header compact i18n />

    <main class="project-page">
      <section class="project-hero">
        <div class="hero-bg"></div>
        <div class="container project-hero-grid">
          <div class="project-hero-copy">
            <p class="eyebrow" data-i18n="project.eyebrow">Project Showcase</p>
            <h1 data-i18n="project.title">Karya digital yang dibangun untuk kebutuhan nyata.</h1>
            <p class="hero-text" data-i18n="project.lead">Lihat bagaimana Solivate Studio membantu komunitas, UMKM, dan brand lokal punya website yang rapi, cepat, dan siap dipakai.</p>
            <div class="hero-actions">
              <a class="btn-primary" href="/#contact">
                <span data-i18n="project.cta.button">Mulai Konsultasi</span>
                <svg class="arrow" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg>
              </a>
              <a class="btn-secondary" href="#showcase" data-i18n="project.list.eyebrow">Selected Work</a>
            </div>
          </div>
          <div class="project-hero-panel" aria-label="Project summary">
            <div>
              <strong data-project-count>0</strong>
              <span data-i18n="project.stat.1.label">Project aktif</span>
            </div>
            <div>
              <strong data-project-market-count>0</strong>
              <span data-i18n="project.stat.2.label">Target pasar</span>
            </div>
            <div>
              <strong data-i18n="project.stat.3.value">Website cepat</strong>
              <span data-i18n="project.stat.3.label">Fokus utama</span>
            </div>
          </div>
        </div>
      </section>

      <section id="showcase" class="section project-showcase-section">
        <div class="container section-head split">
          <div>
            <p class="eyebrow" data-i18n="project.list.eyebrow">Selected Work</p>
            <h2 data-i18n="project.list.title">Showcase website Solivate Studio.</h2>
          </div>
          <p class="lead" data-i18n="project.lead">Lihat bagaimana Solivate Studio membantu komunitas, UMKM, dan brand lokal punya website yang rapi, cepat, dan siap dipakai.</p>
        </div>

        <div class="container project-showcase-grid"></div>
      </section>

      <section class="section project-cta-section">
        <div class="container project-cta-band">
          <p class="eyebrow" data-i18n="project.cta.eyebrow">Mau project seperti ini?</p>
          <h2 data-i18n="project.cta.title">Konsultasi sekarang, gratis. Kita susun scope yang paling masuk akal untuk brand Anda.</h2>
          <a class="btn-primary" href="/#contact">
            <span data-i18n="project.cta.button">Mulai Konsultasi</span>
            <svg class="arrow" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg>
          </a>
        </div>
      </section>
    </main>

    <Footer i18n />
    <script is:inline type="application/ld+json" set:html={collectionSchema}></script>
    <script is:inline type="application/json" id="project-i18n-data" set:html={i18nJson}></script>
    <script is:inline>
      const translations = JSON.parse(document.getElementById("project-i18n-data")?.textContent || "{}");
      const header = document.querySelector("[data-header]");
      const grid = document.querySelector(".project-showcase-grid");
      const projectCount = document.querySelector("[data-project-count]");
      const marketCount = document.querySelector("[data-project-market-count]");

      const escapeHtml = (value) => String(value ?? "").replace(/[&<>"']/g, (char) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        "\"": "&quot;",
        "'": "&#039;"
      }[char]));
      const cmsText = (data, key, lang) => data?.[`${key}_${lang}`] || data?.[`${key}_id`] || data?.[key] || "";

      const updateHeader = () => {
        const y = Math.max(0, window.scrollY);
        header?.classList.toggle("is-scrolled", y > 24);
        header?.classList.toggle("is-compact", y > 64);
      };
      window.addEventListener("scroll", updateHeader, { passive: true });
      updateHeader();

      document.querySelectorAll("[data-top]").forEach((trigger) => {
        trigger.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
      });

      document.querySelectorAll("[data-home-contact]").forEach((trigger) => {
        trigger.addEventListener("click", () => {
          window.location.href = "/#contact";
        });
      });

      const setLanguage = (lang, persist = false) => {
        const activeLang = lang === "en" ? "en" : "id";
        document.documentElement.lang = activeLang;
        if (persist) {
          window.localStorage.setItem("solivate-language", activeLang);
          window.localStorage.setItem("solivate-language-manual", "true");
        }

        document.querySelectorAll("[data-i18n]").forEach((node) => {
          const key = node.getAttribute("data-i18n");
          const next = translations[key]?.[activeLang];
          if (next) node.textContent = next;
        });

        document.querySelectorAll("[data-lang-switch]").forEach((button) => {
          const active = button.getAttribute("data-lang-switch") === activeLang;
          button.classList.toggle("active", active);
          button.setAttribute("aria-pressed", String(active));
        });
      };

      const renderProjects = (items) => {
        const activeLang = document.documentElement.lang === "en" ? "en" : "id";
        const published = Array.isArray(items) ? items : [];
        const labels = new Set();

        projectCount.textContent = String(published.length);

        grid.innerHTML = published.length ? published.map((item, index) => {
          const data = item?.data || {};
          const title = escapeHtml(data.title || "Solivate Studio Project");
          const description = escapeHtml(cmsText(data, "type", activeLang) || cmsText(data, "type", "id") || "Project Showcase");
          const label = escapeHtml(cmsText(data, "type", activeLang) || cmsText(data, "type", "id") || "Project Showcase");
          const url = String(data.url || "#").trim() || "#";
          const external = /^https?:\/\//.test(url);
          const image = escapeHtml(String(data.image_url || "/solivate-logo.webp").trim() || "/solivate-logo.webp");
          if (label) labels.add(label);
          return `<article class="project-showcase-card">
            <a class="project-card-media" href="${escapeHtml(url)}" aria-label="${title}" ${external ? 'target="_blank" rel="noreferrer"' : ""}>
              <img src="${image}" alt="${title}" width="1440" height="900" loading="${index === 0 ? "eager" : "lazy"}" />
            </a>
            <div class="project-card-body">
              <div>
                <span class="project-card-index">${String(index + 1).padStart(2, "0")}</span>
                <h3>${title}</h3>
                <p>${description}</p>
              </div>
              <div class="project-tags">
                <span>${label}</span>
              </div>
              <div class="project-card-actions">
                <a class="btn-primary" href="${escapeHtml(url)}" ${external ? 'target="_blank" rel="noreferrer"' : ""}>
                  <span>${escapeHtml(translations[external ? "project.live" : "project.case"]?.[activeLang] || (external ? "Visit Website" : "View Project"))}</span>
                  <svg class="arrow" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg>
                </a>
              </div>
            </div>
          </article>`;
        }).join("") : `<article class="project-showcase-card"><div class="project-card-body"><div><h3>${escapeHtml(translations["project.empty"]?.[activeLang] || "Belum ada project.")}</h3></div></div></article>`;

        marketCount.textContent = String(labels.size);
      };

      document.querySelectorAll("[data-lang-switch]").forEach((button) => {
        button.addEventListener("click", () => {
          setLanguage(button.getAttribute("data-lang-switch"), true);
          fetch("/api/public/content?type=projects", { cache: "no-store" })
            .then((response) => response.ok ? response.json() : null)
            .then((data) => renderProjects(data?.resources?.projects || []))
            .catch(() => renderProjects([]));
        });
      });

      const savedLanguage = window.localStorage.getItem("solivate-language-manual") === "true"
        ? window.localStorage.getItem("solivate-language")
        : "id";
      setLanguage(savedLanguage || "id");

      fetch("/api/public/content?type=projects", { cache: "no-store" })
        .then((response) => response.ok ? response.json() : null)
        .then((data) => renderProjects(data?.resources?.projects || []))
        .catch(() => renderProjects([]));
    </script>
  </body>
</html>
