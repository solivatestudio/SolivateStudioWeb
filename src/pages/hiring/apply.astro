---
import "../../index.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { siteUrl } from "../../data/seo-pages";

const canonical = `${siteUrl}/hiring/apply`;
const pageTitle = "Formulir Pendaftaran Seleksi | Solivate Studio";
const pageDescription = "Isi formulir pendaftaran untuk bergabung bersama tim Solivate Studio.";

const roleOptions = [
  "apply.pos.1",
  "apply.pos.2",
  "apply.pos.3",
  "apply.pos.4",
  "apply.pos.5",
  "apply.pos.6",
  "apply.pos.7",
  "apply.pos.8"
];

const staticI18n = {
  "nav.about": { id: "Tentang", en: "About" },
  "nav.services": { id: "Layanan", en: "Services" },
  "nav.pricing": { id: "Harga", en: "Pricing" },
  "nav.work": { id: "Karya", en: "Work" },
  "nav.process": { id: "Proses", en: "Process" },
  "nav.contact": { id: "Kontak", en: "Contact" },
  "nav.cta": { id: "Mulai Proyek", en: "Start Project" },
  "apply.eyebrow": { id: "Hiring Form", en: "Hiring Form" },
  "apply.title": { id: "Ceritakan skill dan arah kontribusi kamu.", en: "Tell us your skills and contribution direction." },
  "apply.lead": {
    id: "Isi data inti, link portfolio atau CV, dan alasan kamu ingin bergabung. Kami review secara manual agar kandidat yang cocok bisa dihubungi dengan jelas.",
    en: "Fill in your key details, portfolio or CV link, and reason to join. We review applications manually so suitable candidates can be contacted clearly."
  },
  "apply.panel.1.title": { id: "Review manual", en: "Manual review" },
  "apply.panel.1.desc": { id: "Setiap pendaftaran dibaca oleh tim Solivate.", en: "Every application is reviewed by the Solivate team." },
  "apply.panel.2.title": { id: "Kontak langsung", en: "Direct contact" },
  "apply.panel.2.desc": { id: "Kandidat cocok akan dihubungi via WhatsApp atau email.", en: "Suitable candidates will be contacted via WhatsApp or email." },
  "apply.panel.3.title": { id: "Portfolio penting", en: "Portfolio matters" },
  "apply.panel.3.desc": { id: "Masukkan link CV, GitHub, Drive, Behance, Notion, atau karya terbaik.", en: "Add a CV, GitHub, Drive, Behance, Notion, or best-work link." },
  "apply.form_eyebrow": { id: "Data Pendaftaran", en: "Application Details" },
  "apply.form_title": { id: "Formulir pendaftaran", en: "Application form" },
  "apply.name": { id: "Nama Lengkap", en: "Full Name" },
  "apply.name_placeholder": { id: "Contoh: Hammad Al Fatih", en: "e.g., Hammad Al Fatih" },
  "apply.email": { id: "Alamat Email", en: "Email Address" },
  "apply.email_placeholder": { id: "nama@email.com", en: "name@email.com" },
  "apply.whatsapp": { id: "Nomor WhatsApp", en: "WhatsApp Number" },
  "apply.whatsapp_placeholder": { id: "0812xxxxxxxx", en: "+62 812 xxxx xxxx" },
  "apply.position": { id: "Posisi yang Dilamar", en: "Position Applied For" },
  "apply.position_select": { id: "Pilih posisi", en: "Select a role" },
  "apply.pos.1": { id: "Web Dev Frontend & Backend", en: "Frontend & Backend Web Dev" },
  "apply.pos.2": { id: "Data Analyst & Finance Analyst", en: "Data Analyst & Finance Analyst" },
  "apply.pos.3": { id: "Finance", en: "Finance" },
  "apply.pos.4": { id: "Marketing & SEO/Ads Optimization", en: "Marketing & SEO/Ads Optimization" },
  "apply.pos.5": { id: "Content Creator Instagram/TikTok", en: "Instagram/TikTok Content Creator" },
  "apply.pos.6": { id: "Customer Relations", en: "Customer Relations" },
  "apply.pos.7": { id: "Database Architecture", en: "Database Architecture" },
  "apply.pos.8": { id: "Deploy Specialist", en: "Deploy Specialist" },
  "apply.portfolio": { id: "Link Portfolio / CV", en: "Portfolio / CV Link" },
  "apply.portfolio_placeholder": { id: "https://drive.google.com/... atau https://github.com/...", en: "https://drive.google.com/... or https://github.com/..." },
  "apply.reason": { id: "Alasan Ingin Bergabung", en: "Why Do You Want to Join?" },
  "apply.reason_placeholder": {
    id: "Ceritakan latar belakang singkat, bidang yang kamu minati, skill yang sudah kamu punya, dan kontribusi yang ingin kamu bawa.",
    en: "Tell us your short background, interest area, current skills, and the contribution you want to bring."
  },
  "apply.message": { id: "Pesan Tambahan", en: "Additional Message" },
  "apply.message_placeholder": { id: "Opsional. Tambahkan catatan yang menurut kamu penting.", en: "Optional. Add any note you think matters." },
  "apply.submit": { id: "Kirim Pendaftaran", en: "Submit Application" },
  "apply.sending": { id: "Mengirim...", en: "Sending..." },
  "apply.error": { id: "Pendaftaran belum terkirim. Cek data kamu atau coba lagi beberapa saat.", en: "Application was not sent. Check your details or try again shortly." },
