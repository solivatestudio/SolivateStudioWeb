---
import "../../index.css";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { portfolioPageEnglish, portfolioPages, servicePageEnglish, servicePages, siteUrl } from "../../data/seo-pages";

export const getStaticPaths = () =>
  portfolioPages.map((page) => ({
    params: { slug: page.slug },
    props: { page }
  }));

const { page } = Astro.props;
const pageEn = portfolioPageEnglish[page.slug];
const canonical = `${siteUrl}/portfolio/${page.slug}`;
const title = `${page.title} | Studi Kasus Solivate Studio`;
const relatedServiceSlugs: Record<string, string[]> = {
  "masjid-raya-puri-telukjambe": ["mosque-community-website", "website-development"],
  "cutbae-barbershop": ["barbershop-website", "website-development"],
  "makdian-bakery": ["sme-website", "company-profile-website"]
};
const clientNames: Record<string, string> = {
  "masjid-raya-puri-telukjambe": "Masjid Raya Puri Telukjambe",
  "cutbae-barbershop": "Cutbae Barbershop",
  "makdian-bakery": "Makdian Bakery"
};
const serviceNames: Record<string, string> = {
  "masjid-raya-puri-telukjambe": "Website Masjid & Komunitas",
  "cutbae-barbershop": "Website Barbershop",
  "makdian-bakery": "Website UMKM"
};
const relatedServices = servicePages.filter((item) => (relatedServiceSlugs[page.slug] ?? ["website-development"]).includes(item.slug));
const primaryRelatedService = relatedServices[0]?.slug ?? "website-development";
const staticI18n = {
  "nav.about": { id: "Tentang", en: "About" },
  "nav.services": { id: "Layanan", en: "Services" },
  "nav.pricing": { id: "Harga", en: "Pricing" },
  "nav.work": { id: "Karya", en: "Work" },
  "nav.process": { id: "Proses", en: "Process" },
  "nav.contact": { id: "Kontak", en: "Contact" },
  "nav.cta": { id: "Mulai Proyek", en: "Start Project" },
  "case.eyebrow": { id: "Studi Kasus", en: "Case Study" },
  "case.live": { id: "Lihat Website Live", en: "View Live Website" },
  "case.related": { id: "Layanan Terkait", en: "Related Service" },
  "related.eyebrow": { id: "Layanan Terkait", en: "Related Services" },
  "related.title": {
    id: "Project ini terhubung dengan layanan website yang bisa disesuaikan dengan kebutuhan brand Anda.",
    en: "This project connects with website services that can be adjusted to your brand needs."
  },
  "related.link": { id: "Lihat layanan", en: "View service" },
  "footer.title": { id: "Bangun sesuatu yang orang ingat.", en: "Let's build something people remember." },
  "footer.cta": { id: "Mulai Proyek", en: "Start Project" },
  "footer.desc": {
    id: "Digital solution provider untuk UMKM, komunitas sosial, event, celebration, dan sistem custom yang ingin naik kelas secara digital.",
    en: "Digital solution provider for SMEs, social communities, events, celebrations, and custom systems ready to level up digitally."
  },
  "footer.nav": { id: "Navigasi", en: "Navigation" },
  "footer.connect": { id: "Kontak", en: "Connect" },
  "footer.copy": { id: `Copyright ${new Date().getFullYear()} Solivate Studio. Semua hak dilindungi.`, en: `Copyright ${new Date().getFullYear()} Solivate Studio. All rights reserved.` },
  "footer.top": { id: "Kembali ke atas", en: "Back to top" },
  "floating.wa": { id: "Konsultasi sekarang, gratis!", en: "Free consultation now!" }
};
const pageI18n = {
  "page.title": { id: page.title, en: pageEn.title },
  "page.description": { id: page.description, en: pageEn.description },
  ...Object.fromEntries(page.highlights.map((item, index) => [`highlight.${index}`, { id: item, en: pageEn.highlights[index] }])),
  ...Object.fromEntries(page.sections.flatMap((section, index) => [
    [`section.${index}.title`, { id: section.title, en: pageEn.sections[index].title }],
    [`section.${index}.body`, { id: section.body, en: pageEn.sections[index].body }]
  ])),
  ...Object.fromEntries(relatedServices.flatMap((service, index) => [
    [`service.${index}.title`, { id: service.eyebrow, en: servicePageEnglish[service.slug].eyebrow }],
    [`service.${index}.desc`, { id: service.description, en: servicePageEnglish[service.slug].description }]
  ]))
};
const i18nJson = JSON.stringify({ ...staticI18n, ...pageI18n });
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CreativeWork",
  name: page.title,
  creator: {
    "@type": "Organization",
    name: "Solivate Studio",
    url: siteUrl
  },
  url: canonical,
  image: `${siteUrl}${page.image}`,
  description: page.description,
  keywords: page.keywords
});
const gaId = import.meta.env.PUBLIC_GA_ID || "G-H1R8S8W5W6";
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={page.description} />
    <meta name="keywords" content={page.keywords.join(", ")} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="Solivate Studio" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={page.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${siteUrl}${page.image}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={page.description} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
      @media (max-width: 768px) {
        .seo-responsive-signal { display: block; }
      }
    </style>
    {gaId && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script is:inline define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
  </head>
  <body>
    <Header compact i18n />

    <main class="seo-page">
      <section class="seo-hero portfolio-case-hero">
        <div class="hero-bg"></div>
        <div class="container seo-hero-grid">
          <div class="hero-content-left">
            <div class="case-meta-eyebrow">
              <span class="eyebrow" data-i18n="case.eyebrow">Studi Kasus</span>
              <span class="meta-dot"></span>
              <span class="meta-service">{serviceNames[page.slug] ?? "Web Development"}</span>
            </div>
            <h1 class="case-title" data-i18n="page.title">{page.title}</h1>
            <p class="hero-text" data-i18n="page.description">{page.description}</p>
            
            <div class="case-metadata-bar">
              <div class="meta-item">
                <small>Klien</small>
                <strong>{clientNames[page.slug] ?? "Partner"}</strong>
              </div>
              <div class="meta-item">
                <small>Tahun</small>
                <strong>2026</strong>
              </div>
              <div class="meta-item">
                <small>Kategori</small>
                <strong>Tailored System</strong>
              </div>
            </div>

            <div class="hero-actions">
              <a class="btn-primary" href={page.url} target="_blank" rel="noreferrer">
                <span data-i18n="case.live">Lihat Website Live</span>
                <svg class="arrow" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg>
              </a>
              <a class="btn-secondary" href={`/layanan/${primaryRelatedService}`} data-i18n="case.related">Layanan Terkait</a>
            </div>
          </div>
          
          <div class="case-mockup-wrapper">
            <div class="browser-mockup">
              <div class="browser-header">
                <span class="dot red"></span>
                <span class="dot yellow"></span>
                <span class="dot green"></span>
                <div class="browser-url">https://solivate.com/{page.slug}</div>
              </div>
              <div class="browser-viewport">
                <img src={page.image} alt={page.title} width={page.width} height={page.height} loading="eager" />
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section light">
        <div class="container">
          <div class="section-head center">
            <p class="eyebrow" data-i18n="case.eyebrow">Sorotan Utama</p>
            <h2>Fitur & Solusi Kunci Proyek</h2>
          </div>
          <div class="seo-feature-grid">
            {page.highlights.map((item, index) => (
              <article class="feature-card highlight-bento-card">
                <div class="card-glow"></div>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3 data-i18n={`highlight.${index}`}>{item}</h3>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section narrative-story-section">
        <div class="container narrative-container">
          {page.sections.map((section, index) => (
            <div class={`narrative-row ${index % 2 === 1 ? "reverse" : ""}`}>
              <div class="narrative-col text-col">
                <span class="narrative-num">0{index + 1} / {section.title}</span>
                <h2 class="narrative-title">{section.title === "Tantangan" ? "Apa Masalahnya?" : section.title === "Solusi" ? "Bagaimana Kami Membantu?" : "Apa Hasil Akhirnya?"}</h2>
                <p class="narrative-body" data-i18n={`section.${index}.body`}>{section.body}</p>
              </div>
              <div class="narrative-col visual-col">
                {index === 0 && (
                  <div class="decorative-quote-card">
                    <span class="quote-icon">“</span>
                    <p>Membantu mitra bertransformasi secara digital dengan alur informasi yang rapi, transparan, dan terpercaya.</p>
                  </div>
                )}
                {index === 1 && (
                  <div class="decorative-tech-stack">
                    <div class="tech-tag">Astro SSG</div>
                    <div class="tech-tag">TypeScript</div>
                    <div class="tech-tag">Custom CSS</div>
                    <div class="tech-tag">SEO Schema</div>
                    <div class="tech-tag">Responsive UI</div>
                  </div>
                )}
                {index === 2 && (
                  <div class="decorative-stat-card">
                    <strong>100%</strong>
                    <p>Kredibilitas Digital Terjamin & Siap Rilis</p>
                  </div>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>

      <section class="section light">
        <div class="container section-head">
          <p class="eyebrow" data-i18n="related.eyebrow">Layanan Terkait</p>
          <h2 data-i18n="related.title">Halaman ini terhubung dengan layanan website yang bisa disesuaikan dengan kebutuhan brand Anda.</h2>
        </div>
        <div class="container service-grid">
          {relatedServices.map((service, index) => (
            <article class="service-card">
              <div class="icon-box">SS</div>
              <p class="card-heading" data-i18n={`service.${index}.title`}>{service.eyebrow}</p>
              <p data-i18n={`service.${index}.desc`}>{service.description}</p>
              <a href={`/layanan/${service.slug}`}><span data-i18n="related.link">Lihat layanan</span> <svg class="arrow" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg></a>
            </article>
          ))}
        </div>
      </section>
    </main>

    <Footer i18n />
    <script is:inline type="application/ld+json" set:html={schema}></script>
    <script is:inline type="application/json" id="portfolio-i18n-data" set:html={i18nJson}></script>
    <script is:inline>
      const translations = JSON.parse(document.getElementById("portfolio-i18n-data")?.textContent || "{}");
      const header = document.querySelector("[data-header]");
      const updateHeader = () => {
        const y = Math.max(0, window.scrollY);
        header?.classList.toggle("is-scrolled", y > 24);
        header?.classList.toggle("is-compact", y > 64);
      };
      window.addEventListener("scroll", updateHeader, { passive: true });
      updateHeader();

      document.querySelectorAll("[data-top]").forEach((trigger) => {
        trigger.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
      });

      document.querySelectorAll("[data-home-contact]").forEach((trigger) => {
        trigger.addEventListener("click", () => {
          window.location.href = "/#contact";
        });
      });

      const setLanguage = (lang, persist = false) => {
        const activeLang = lang === "en" ? "en" : "id";
        document.documentElement.lang = activeLang;
        if (persist) {
          window.localStorage.setItem("solivate-language", activeLang);
          window.localStorage.setItem("solivate-language-manual", "true");
        }

        document.querySelectorAll("[data-i18n]").forEach((node) => {
          const key = node.getAttribute("data-i18n");
          const next = translations[key]?.[activeLang];
          if (next) node.textContent = next;
        });

        document.querySelectorAll("[data-lang-switch]").forEach((button) => {
          const active = button.getAttribute("data-lang-switch") === activeLang;
          button.classList.toggle("active", active);
          button.setAttribute("aria-pressed", String(active));
        });
      };

      document.querySelectorAll("[data-lang-switch]").forEach((button) => {
        button.addEventListener("click", () => setLanguage(button.getAttribute("data-lang-switch"), true));
      });
      const savedLanguage = window.localStorage.getItem("solivate-language-manual") === "true"
        ? window.localStorage.getItem("solivate-language")
        : "id";
      setLanguage(savedLanguage || "id");
    </script>
  </body>
</html>
