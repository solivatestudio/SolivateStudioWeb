---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---
<DashboardLayout title="Team Performance" active="performance" eyebrow="Lightweight KPI">
  <section class="admin-intro"><div><h2>Ukur output yang benar-benar berguna.</h2><p>KPI ringan untuk delivery, leads, revenue, dan kualitas kerja. Nilai dapat diperbarui kapan saja tanpa histori yang rumit.</p></div><button class="admin-button accent" type="button" data-add-kpi>Update KPI</button></section>
  <section class="admin-grid stats management-list-section" data-kpi-list><div class="admin-empty" style="grid-column:1/-1">Memuat KPI...</div></section>
  <section class="admin-panel management-editor" style="margin-bottom:16px">
    <div class="admin-panel-head"><div><h2>Update KPI</h2><p>Key yang sama akan memperbarui metrik lama.</p></div></div>
    <form class="admin-form" data-kpi-form>
      <label class="admin-field"><span>Metric key</span><input name="metric_key" placeholder="projects_delivered" required /></label>
      <label class="admin-field"><span>Label</span><input name="label" placeholder="Projects delivered" required /></label>
      <label class="admin-field"><span>Nilai</span><input name="value" type="number" step="0.01" required /></label>
      <label class="admin-field"><span>Target</span><input name="target" type="number" step="0.01" required /></label>
      <label class="admin-field"><span>Unit</span><input name="unit" placeholder="project, %, Rp" /></label>
      <label class="admin-field"><span>Periode</span><input name="period" placeholder="Juli 2026" /></label>
      <div class="admin-actions full"><button class="admin-button accent" type="submit">Simpan KPI</button></div>
    </form>
  </section>
  <script is:inline>
    window.addEventListener("DOMContentLoaded", () => {
      const form = document.querySelector("[data-kpi-form]"); const list = document.querySelector("[data-kpi-list]");
      const esc = (value) => String(value ?? "").replace(/[&<>"']/g, (c) => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"}[c]));
      const load = async () => { const { items } = await window.adminApi("/api/admin/data?resource=performance"); list.innerHTML = items.length ? items.map((item,index) => { const percent = Number(item.target) ? Math.min(100, Math.round(Number(item.value)/Number(item.target)*100)) : 0; return `<article class="admin-stat ${index%3===1?'blue':index%3===2?'coral':''}"><p class="admin-stat-label">${esc(item.label)}</p><div class="admin-stat-value">${esc(item.unit)==='Rp'?window.formatRupiah(item.value):`${Number(item.value).toLocaleString('id-ID')} ${esc(item.unit)}`}</div><span class="admin-stat-note">${percent}% dari target ${Number(item.target).toLocaleString('id-ID')} · ${esc(item.period)}</span></article>`; }).join("") : '<div class="admin-empty" style="grid-column:1/-1">Belum ada KPI. Tambahkan metrik pertama di atas.</div>'; };
      form.addEventListener("submit", async (event) => { event.preventDefault(); try { await window.adminApi("/api/admin/data?resource=performance", { method:"PUT", body:JSON.stringify(Object.fromEntries(new FormData(form))) }); form.reset(); await load(); window.showAdminToast("KPI berhasil diperbarui."); } catch(error) { window.showAdminToast(error.message,"error"); } });
      document.querySelector("[data-add-kpi]")?.addEventListener("click", () => form.scrollIntoView({ behavior: "smooth", block: "start" }));
      load().catch((error) => { list.innerHTML = `<p class="admin-error" style="grid-column:1/-1">${esc(error.message)}</p>`; });
    });
  </script>
</DashboardLayout>
