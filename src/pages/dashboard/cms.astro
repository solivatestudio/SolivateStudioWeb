---
import DashboardLayout from "../../layouts/DashboardLayout.astro";

const modules = [
  {
    label: "Pricing packages",
    href: "/dashboard/cms/pricing",
    metric: "7 paket",
    text: "Kelola nama paket, harga, benefit, status featured, dan tampilan homepage."
  },
  {
    label: "Project showcase",
    href: "/dashboard/cms/projects",
    metric: "Portfolio",
    text: "Tambah project, link live site, urutan tampil, dan upload thumbnail WebP/JPG/PNG."
  },
  {
    label: "FAQ website",
    href: "/dashboard/cms/faq",
    metric: "Q&A",
    text: "Atur pertanyaan yang muncul di contact section dalam bahasa Indonesia dan Inggris."
  },
  {
    label: "Contact settings",
    href: "/dashboard/cms/contact",
    metric: "Medsos",
    text: "Update email bisnis, WhatsApp, Instagram, dan CTA kontak utama."
  }
];
---

<DashboardLayout title="Website CMS" active="cms" mode="cms" eyebrow="Content management">
  <section class="cms-home-hero">
    <div>
      <p class="cms-kicker">Website content</p>
      <h2>Kelola konten yang sering berubah tanpa sentuh kode.</h2>
      <p>Pricing, project showcase, FAQ, dan kontak dipisah sebagai resource CMS agar alurnya jelas: tambah data, edit, upload gambar, reorder, publish.</p>
    </div>
    <a class="admin-button accent" href="/" target="_blank" rel="noreferrer">Preview website</a>
  </section>

  <section class="cms-resource-grid">
    {modules.map((item, index) => (
      <a class="cms-module-card" href={item.href}>
        <span>0{index + 1}</span>
        <small>{item.metric}</small>
        <h3>{item.label}</h3>
        <p>{item.text}</p>
      </a>
    ))}
  </section>
</DashboardLayout>
