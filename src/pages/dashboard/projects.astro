---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Project Management" active="projects" eyebrow="Delivery desk">
  <section class="admin-intro">
    <div>
      <h2>Project, uang, timeline, dan dokumen dalam satu meja.</h2>
      <p>Setiap project punya breakdown budget, biaya operasional, fee PIC, profit, termin deadline, dokumen invoice/MOU, dan status pembayaran.</p>
    </div>
    <button class="admin-button accent" type="button" data-new-project>Tambah project</button>
  </section>

  <section class="admin-grid stats project-summary-grid" style="margin-bottom:16px">
    <article class="admin-stat"><p class="admin-stat-label">Booked value</p><div class="admin-stat-value" data-project-booked>Rp0</div><span class="admin-stat-note">Total budget project</span></article>
    <article class="admin-stat blue"><p class="admin-stat-label">Payment received</p><div class="admin-stat-value" data-project-received>Rp0</div><span class="admin-stat-note">Pembayaran masuk</span></article>
    <article class="admin-stat coral"><p class="admin-stat-label">Outstanding</p><div class="admin-stat-value" data-project-outstanding>Rp0</div><span class="admin-stat-note">Belum lunas / DP</span></article>
    <article class="admin-stat"><p class="admin-stat-label">Projected profit</p><div class="admin-stat-value" data-project-profit>Rp0</div><span class="admin-stat-note">Budget - cost - fee PIC</span></article>
  </section>

  <section class="admin-panel project-workspace" style="margin-bottom:16px">
    <div class="admin-panel-head">
      <div><h2 data-project-form-title>Tambah project</h2><p>Isi data inti proyek dan breakdown keuangan yang dipakai rekap rapat.</p></div>
      <button class="admin-button ghost" type="button" data-project-reset>Reset</button>
    </div>
    <form class="admin-form project-form" data-project-form>
      <input type="hidden" name="id" />
      <label class="admin-field"><span>Nama project</span><input name="name" required /></label>
      <label class="admin-field"><span>Client</span><input name="client" /></label>
      <label class="admin-field"><span>Status project</span><select name="status"><option value="planning">Planning</option><option value="active">On progress</option><option value="review">Review</option><option value="pending">Pending</option><option value="on-hold">On hold</option><option value="completed">Completed</option></select></label>
      <label class="admin-field"><span>Status pembayaran</span><select name="payment_status"><option value="unpaid">Belum bayar</option><option value="dp">DP</option><option value="pending">Pending</option><option value="overdue">Overdue</option><option value="paid">Lunas</option></select></label>
      <label class="admin-field"><span>Tanggal mulai</span><input name="start_date" type="date" /></label>
      <label class="admin-field"><span>Deadline final</span><input name="deadline" type="date" /></label>
      <label class="admin-field"><span>Progress (%)</span><input name="progress" type="number" min="0" max="100" value="0" /></label>
      <label class="admin-field"><span>Budget project</span><input name="budget" type="number" min="0" step="1000" /></label>
      <label class="admin-field"><span>Biaya operasional</span><input name="operational_cost" type="number" min="0" step="1000" /></label>
      <label class="admin-field"><span>Fee PIC</span><input name="pic_fee" type="number" min="0" step="1000" /></label>
      <label class="admin-field"><span>Pembayaran diterima</span><input name="payment_received" type="number" min="0" step="1000" /></label>
      <label class="admin-field full"><span>Catatan</span><textarea name="notes"></textarea></label>
      <div class="admin-actions full"><button class="admin-button accent" type="submit">Simpan project</button></div>
    </form>
  </section>

  <section class="admin-grid two" style="margin-bottom:16px">
    <article class="admin-panel">
      <div class="admin-panel-head"><div><h2>Termin / timeline</h2><p>Deadline per termin biar ketahuan yang telat.</p></div></div>
      <form class="admin-form compact-form" data-milestone-form>
        <input type="hidden" name="id" />
        <label class="admin-field full"><span>Project</span><select name="project_id" required></select></label>
        <label class="admin-field"><span>Termin</span><input name="title" placeholder="Termin 1 - desain" required /></label>
        <label class="admin-field"><span>Deadline termin</span><input name="due_date" type="date" /></label>
        <label class="admin-field"><span>Status</span><select name="status"><option value="pending">Pending</option><option value="on-progress">On progress</option><option value="completed">Completed</option><option value="late">Late</option></select></label>
        <label class="admin-field"><span>Nominal</span><input name="amount" type="number" min="0" step="1000" /></label>
        <label class="admin-field full"><span>Catatan</span><input name="notes" /></label>
        <div class="admin-actions full"><button class="admin-button accent" type="submit">Simpan termin</button><button class="admin-button ghost" type="button" data-milestone-reset>Reset</button></div>
      </form>
    </article>

    <article class="admin-panel">
      <div class="admin-panel-head"><div><h2>Dokumen project</h2><p>Invoice, MOU, receipt, dan dokumen operasional.</p></div></div>
      <form class="admin-form compact-form" data-document-form>
        <input type="hidden" name="id" />
        <label class="admin-field full"><span>Project</span><select name="project_id" required></select></label>
        <label class="admin-field"><span>Judul dokumen</span><input name="title" required /></label>
        <label class="admin-field"><span>Tipe</span><select name="document_type"><option value="invoice">Invoice</option><option value="mou">MOU</option><option value="receipt">Receipt</option><option value="operational">Biaya operasional</option><option value="contract">Kontrak</option><option value="other">Lainnya</option></select></label>
        <label class="admin-field"><span>Status</span><select name="status"><option value="draft">Draft</option><option value="sent">Sent</option><option value="paid">Paid</option><option value="signed">Signed</option><option value="archived">Archived</option></select></label>
        <label class="admin-field"><span>Tanggal</span><input name="issued_date" type="date" /></label>
        <label class="admin-field"><span>Nominal</span><input name="amount" type="number" min="0" step="1000" /></label>
        <label class="admin-field full"><span>File URL</span><input name="file_url" type="url" placeholder="Upload atau paste link dokumen" /></label>
        <label class="admin-field full"><span>Upload dokumen</span><input type="file" data-doc-upload accept="application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/png,image/jpeg,image/webp" /></label>
        <label class="admin-field full"><span>Catatan</span><input name="notes" /></label>
        <div class="admin-actions full"><button class="admin-button accent" type="submit">Simpan dokumen</button><button class="admin-button ghost" type="button" data-document-reset>Reset</button></div>
      </form>
    </article>
  </section>

  <section class="admin-panel">
    <div class="admin-panel-head"><div><h2>Project list</h2><p data-project-count>Memuat data...</p></div></div>
    <div data-project-list><div class="admin-empty">Memuat project...</div></div>
  </section>

  <script is:inline>
    window.addEventListener("DOMContentLoaded", () => {
      const projectForm = document.querySelector("[data-project-form]");
      const milestoneForm = document.querySelector("[data-milestone-form]");
      const documentForm = document.querySelector("[data-document-form]");
      const list = document.querySelector("[data-project-list]");
      let items = [];
      const esc = (value) => String(value ?? "").replace(/[&<>"']/g, (c) => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"}[c]));
      const iso = (value) => value ? String(value).slice(0,10) : "";
      const money = (value) => window.formatRupiah(Number(value || 0));
      const statusLabel = (status) => ({ active: "on progress", "on-hold": "on hold", unpaid: "belum bayar", paid: "lunas" }[status] || status);
      const resetProject = () => { projectForm.reset(); projectForm.elements.id.value = ""; projectForm.elements.progress.value = 0; document.querySelector("[data-project-form-title]").textContent = "Tambah project"; };
      const fillSelects = () => {
        const options = ['<option value="">Pilih project</option>', ...items.map((item) => `<option value="${esc(item.id)}">${esc(item.name)} · ${esc(item.client || "Internal")}</option>`)].join("");
        milestoneForm.elements.project_id.innerHTML = options;
        documentForm.elements.project_id.innerHTML = options;
      };
      const totals = () => {
        const sum = (key) => items.reduce((total, item) => total + Number(item[key] || 0), 0);
        document.querySelector("[data-project-booked]").textContent = money(sum("budget"));
        document.querySelector("[data-project-received]").textContent = money(sum("payment_received"));
        document.querySelector("[data-project-outstanding]").textContent = money(sum("outstanding"));
        document.querySelector("[data-project-profit]").textContent = money(items.reduce((total, item) => total + Number(item.profit_plan || 0), 0));
      };
      const milestoneRows = (project) => project.milestones?.length ? project.milestones.map((item) => {
        const late = item.status !== "completed" && item.due_date && new Date(item.due_date) < new Date(new Date().toISOString().slice(0,10));
        return `<div class="ops-row ${late ? "late" : ""}"><div><strong>${esc(item.title)}</strong><span>${window.formatDate(item.due_date)} · ${money(item.amount)}</span></div><em>${late ? "late" : esc(item.status)}</em><button class="admin-button ghost" data-edit-milestone="${esc(item.id)}">Edit</button><button class="admin-button danger" data-delete-milestone="${esc(item.id)}">Hapus</button></div>`;
      }).join("") : '<div class="admin-empty">Belum ada termin.</div>';
      const documentRows = (project) => project.documents?.length ? project.documents.map((item) => `<div class="ops-row"><div><strong>${esc(item.title)}</strong><span>${esc(item.document_type)} · ${window.formatDate(item.issued_date)} · ${money(item.amount)}</span></div><em>${esc(item.status)}</em>${item.file_url ? `<a class="admin-button ghost" href="${esc(item.file_url)}" target="_blank" rel="noreferrer">Buka</a>` : ""}<button class="admin-button ghost" data-edit-document="${esc(item.id)}">Edit</button><button class="admin-button danger" data-delete-document="${esc(item.id)}">Hapus</button></div>`).join("") : '<div class="admin-empty">Belum ada dokumen.</div>';
      const render = () => {
        document.querySelector("[data-project-count]").textContent = `${items.length} project tercatat`;
        totals(); fillSelects();
        if (!items.length) { list.innerHTML = '<div class="admin-empty">Belum ada project. Tambahkan project pertama di atas.</div>'; return; }
        list.innerHTML = items.map((item) => `<article class="project-command-card">
            <header>
              <div><span class="admin-badge ${esc(item.status)}">${esc(statusLabel(item.status))}</span><h3>${esc(item.name)}</h3><p>${esc(item.client || "Internal")} · ${window.formatDate(item.start_date)} - ${window.formatDate(item.deadline)}</p></div>
              <div class="admin-actions"><button class="admin-button ghost" data-edit-project="${esc(item.id)}">Edit</button><button class="admin-button danger" data-delete-project="${esc(item.id)}">Hapus</button></div>
            </header>
            <div class="project-money-grid">
              <div><small>Budget</small><strong>${money(item.budget)}</strong></div>
              <div><small>Ops cost</small><strong>${money(item.operational_cost)}</strong></div>
              <div><small>Fee PIC</small><strong>${money(item.pic_fee)}</strong></div>
              <div><small>Profit plan</small><strong>${money(item.profit_plan)}</strong></div>
              <div><small>Received</small><strong>${money(item.payment_received || item.income_total)}</strong></div>
              <div><small>Outstanding</small><strong>${money(item.outstanding)}</strong></div>
            </div>
            <div class="project-status-line"><div class="admin-progress"><span style="width:${Number(item.progress || 0)}%"></span></div><span>${Number(item.progress || 0)}%</span><em class="admin-badge ${esc(item.payment_status)}">${esc(statusLabel(item.payment_status))}</em></div>
            <div class="project-subgrid"><section><h4>Timeline termin</h4>${milestoneRows(item)}</section><section><h4>Dokumen</h4>${documentRows(item)}</section></div>
          </article>`).join("");
      };
      const load = async () => { const data = await window.adminApi("/api/admin/data?resource=projects"); items = data.items || []; render(); };
      const submit = async (resource, form) => {
        const data = Object.fromEntries(new FormData(form));
        await window.adminApi(`/api/admin/data?resource=${resource}`, { method: data.id ? "PUT" : "POST", body: JSON.stringify(data) });
        form.reset(); if (form.elements.id) form.elements.id.value = "";
        await load(); window.showAdminToast("Data berhasil disimpan.");
      };
      projectForm.addEventListener("submit", async (event) => { event.preventDefault(); try { await submit("projects", projectForm); resetProject(); } catch (error) { window.showAdminToast(error.message, "error"); } });
      milestoneForm.addEventListener("submit", async (event) => { event.preventDefault(); try { await submit("milestones", milestoneForm); } catch (error) { window.showAdminToast(error.message, "error"); } });
      documentForm.addEventListener("submit", async (event) => { event.preventDefault(); try { await submit("documents", documentForm); } catch (error) { window.showAdminToast(error.message, "error"); } });
      document.querySelector("[data-project-reset]").addEventListener("click", resetProject);
      document.querySelector("[data-milestone-reset]").addEventListener("click", () => milestoneForm.reset());
      document.querySelector("[data-document-reset]").addEventListener("click", () => documentForm.reset());
      document.querySelector("[data-new-project]").addEventListener("click", () => { resetProject(); projectForm.scrollIntoView({ behavior: "smooth" }); });
      document.querySelector("[data-doc-upload]").addEventListener("change", async (event) => {
        const file = event.target.files?.[0]; if (!file) return;
        try {
          const response = await fetch(`/api/admin/upload?filename=${encodeURIComponent(file.name)}`, { method: "POST", credentials: "same-origin", headers: { "Content-Type": file.type }, body: file });
          const data = await response.json().catch(() => ({})); if (!response.ok) throw new Error(data.message || "Upload gagal.");
          documentForm.elements.file_url.value = data.url; window.showAdminToast("Dokumen berhasil diupload.");
        } catch (error) { window.showAdminToast(error.message, "error"); } finally { event.target.value = ""; }
      });
      list.addEventListener("click", async (event) => {
        const projectId = event.target.closest("[data-edit-project]")?.dataset.editProject;
        const deleteProject = event.target.closest("[data-delete-project]")?.dataset.deleteProject;
        const milestoneId = event.target.closest("[data-edit-milestone]")?.dataset.editMilestone;
        const deleteMilestone = event.target.closest("[data-delete-milestone]")?.dataset.deleteMilestone;
        const documentId = event.target.closest("[data-edit-document]")?.dataset.editDocument;
        const deleteDocument = event.target.closest("[data-delete-document]")?.dataset.deleteDocument;
        if (projectId) { const item = items.find((entry) => entry.id === projectId); Object.entries(item).forEach(([key, value]) => { if (projectForm.elements[key]) projectForm.elements[key].value = ["start_date","deadline"].includes(key) ? iso(value) : value ?? ""; }); document.querySelector("[data-project-form-title]").textContent = "Edit project"; projectForm.scrollIntoView({ behavior: "smooth" }); }
        if (milestoneId) { const item = items.flatMap((entry) => entry.milestones || []).find((entry) => entry.id === milestoneId); Object.entries(item).forEach(([key, value]) => { if (milestoneForm.elements[key]) milestoneForm.elements[key].value = key === "due_date" ? iso(value) : value ?? ""; }); milestoneForm.scrollIntoView({ behavior: "smooth" }); }
        if (documentId) { const item = items.flatMap((entry) => entry.documents || []).find((entry) => entry.id === documentId); Object.entries(item).forEach(([key, value]) => { if (documentForm.elements[key]) documentForm.elements[key].value = key === "issued_date" ? iso(value) : value ?? ""; }); documentForm.scrollIntoView({ behavior: "smooth" }); }
        if (deleteProject && confirm("Hapus project ini beserta termin dan dokumennya?")) { await window.adminApi("/api/admin/data?resource=projects", { method: "DELETE", body: JSON.stringify({ id: deleteProject }) }); await load(); }
        if (deleteMilestone && confirm("Hapus termin ini?")) { await window.adminApi("/api/admin/data?resource=milestones", { method: "DELETE", body: JSON.stringify({ id: deleteMilestone }) }); await load(); }
        if (deleteDocument && confirm("Hapus dokumen ini?")) { await window.adminApi("/api/admin/data?resource=documents", { method: "DELETE", body: JSON.stringify({ id: deleteDocument }) }); await load(); }
      });
      load().catch((error) => { list.innerHTML = `<p class="admin-error">${esc(error.message)}</p>`; });
    });
  </script>
</DashboardLayout>
