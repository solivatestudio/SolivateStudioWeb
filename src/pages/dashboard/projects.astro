---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---

<DashboardLayout title="Project Management" active="projects" eyebrow="Delivery desk">
  <section class="admin-intro">
    <div>
      <h2>Project, uang, timeline, dan dokumen dalam satu meja.</h2>
      <p>Wizard 5-langkah: info project → scope → model harga → termin & dokumen → generate invoice siap kirim ke client.</p>
    </div>
    <button class="admin-button accent" type="button" data-open-wizard>＋ Tambah project</button>
  </section>

  <section class="admin-grid stats project-summary-grid management-summary" style="margin-bottom:16px">
    <article class="admin-stat"><p class="admin-stat-label">Booked value</p><div class="admin-stat-value" data-project-booked>Rp0</div><span class="admin-stat-note">Total budget project</span></article>
    <article class="admin-stat blue"><p class="admin-stat-label">Payment received</p><div class="admin-stat-value" data-project-received>Rp0</div><span class="admin-stat-note">Pembayaran masuk</span></article>
    <article class="admin-stat coral"><p class="admin-stat-label">Outstanding</p><div class="admin-stat-value" data-project-outstanding>Rp0</div><span class="admin-stat-note">Belum lunas / DP</span></article>
    <article class="admin-stat"><p class="admin-stat-label">Projected profit</p><div class="admin-stat-value" data-project-profit>Rp0</div><span class="admin-stat-note">Budget - cost - fee PIC</span></article>
  </section>

  <section class="admin-panel management-list-section">
    <div class="admin-panel-head">
      <div><h2>Project list</h2><p data-project-count>Memuat data...</p></div>
      <button class="admin-button accent" type="button" data-open-wizard>＋ Tambah project</button>
    </div>
    <div data-project-list><div class="admin-empty">Memuat project...</div></div>
  </section>

  <div data-wizard-host hidden>
    <section class="wizard-shell" data-wizard>
      <div class="wizard-progress" data-wizard-progress>
        <div class="wizard-progress-bar" data-wizard-bar style="width:0%"></div>
        <div class="wizard-step active" data-step-indicator="1"><div class="wizard-step-circle">1</div><div class="wizard-step-label">Info Dasar</div></div>
        <div class="wizard-step" data-step-indicator="2"><div class="wizard-step-circle">2</div><div class="wizard-step-label">Scope</div></div>
        <div class="wizard-step" data-step-indicator="3"><div class="wizard-step-circle">3</div><div class="wizard-step-label">Harga</div></div>
        <div class="wizard-step" data-step-indicator="4"><div class="wizard-step-circle">4</div><div class="wizard-step-label">Termin</div></div>
        <div class="wizard-step" data-step-indicator="5"><div class="wizard-step-circle">5</div><div class="wizard-step-label">Invoice</div></div>
      </div>

      <form data-wizard-form>
        <input type="hidden" name="id" />

        <div class="wizard-panel active" data-step-panel="1">
          <div class="wizard-panel-head">
            <h2>Informasi dasar project</h2>
            <p>Nama project, client, tipe, dan tanggal. Bisa diedit lagi nanti.</p>
          </div>
          <div class="admin-form project-form">
            <label class="admin-field"><span>Nama project *</span><input name="name" required placeholder="Website company profile PT ..." /></label>
            <label class="admin-field"><span>Client</span><input name="client" placeholder="Nama perusahaan / personal" /></label>
            <label class="admin-field"><span>Kontak client (WA / email)</span><input name="client_contact" placeholder="08xxx / client@email.com" /></label>
            <label class="admin-field"><span>Alamat client</span><input name="client_address" placeholder="Kota, provinsi" /></label>
            <label class="admin-field"><span>Tipe project</span>
              <select name="project_type">
                <option value="umkm">UMKM</option>
                <option value="masjid">Masjid</option>
                <option value="event">Event</option>
                <option value="wedding">Wedding</option>
                <option value="company">Company / Corporate</option>
                <option value="other">Lainnya</option>
              </select>
            </label>
            <label class="admin-field"><span>Status project</span>
              <select name="status">
                <option value="planning">Planning</option>
                <option value="active">On progress</option>
                <option value="review">Review</option>
                <option value="pending">Pending</option>
                <option value="on-hold">On hold</option>
                <option value="completed">Completed</option>
              </select>
            </label>
            <label class="admin-field"><span>Tanggal mulai *</span><input name="start_date" type="date" required /></label>
            <label class="admin-field"><span>Deadline final *</span><input name="deadline" type="date" required /></label>
            <label class="admin-field full"><span>Catatan internal</span><textarea name="notes" rows="5" placeholder="- PIC: Hammad&#10;- Link drive: https://...&#10;- Catatan meeting: client minta hero direvisi&#10;- Todo internal: follow up copywriting"></textarea></label>
          </div>
        </div>

        <div class="wizard-panel" data-step-panel="2">
          <div class="wizard-panel-head">
            <h2>Scope & deliverables</h2>
            <p>Jelaskan apa yang akan dibangun. Scope untuk invoice, features untuk checklist pekerjaan.</p>
          </div>
          <div class="admin-form">
            <label class="admin-field full"><span>Scope project (untuk client)</span><textarea name="scope" rows="4" placeholder="Contoh: Website company profile 5 halaman dengan CMS konten, integrasi WhatsApp, SEO dasar, training 1 sesi."></textarea></label>
            <label class="admin-field full"><span>Fitur / deliverables (satu per baris)</span><textarea name="features" rows="6" placeholder="- Landing page modern&#10;- Halaman About / Services / Portfolio / Contact&#10;- CMS blog sederhana&#10;- Integrasi WhatsApp&#10;- SEO on-page dasar"></textarea></label>
            <label class="admin-field full"><span>Developer assignment (Role | Nama | Tanggung jawab)</span><textarea name="team_assignments" rows="5" placeholder="Tech Lead | Hammad | Arsitektur, review, keputusan teknis&#10;Backend Developer | Nama tim | API, database, invoice, auth&#10;Frontend Developer | Nama tim | UI, responsive, interaksi&#10;DevOps Engineer | Nama tim | Deploy, domain, monitoring"></textarea></label>
          </div>
        </div>

        <div class="wizard-panel" data-step-panel="3">
          <div class="wizard-panel-head">
            <h2>Model harga</h2>
            <p>Pilih fixed price (1 nominal total) atau per-fitur (line items terpisah). Bisa diubah nanti.</p>
          </div>
          <div class="wizard-pricing-toggle">
            <label class="wizard-pricing-card selected" data-pricing-card="fixed">
              <input type="radio" name="pricing_model" value="fixed" checked />
              <div class="wizard-pricing-check">✓</div>
              <h4>Fixed Price</h4>
              <p>Satu nominal total untuk seluruh project. Cocok untuk paket standar.</p>
            </label>
            <label class="wizard-pricing-card" data-pricing-card="line_items">
              <input type="radio" name="pricing_model" value="line_items" />
              <div class="wizard-pricing-check">✓</div>
              <h4>Per-Fitur / Item</h4>
              <p>Pisah per fitur dengan harga masing-masing. Lebih fleksibel untuk client.</p>
            </label>
          </div>
          <div data-pricing-fixed>
            <label class="admin-field"><span>Total budget project *</span><input name="budget" inputmode="numeric" data-money placeholder="0" /></label>
          </div>
          <div data-pricing-items hidden>
            <p style="margin:0 0 10px;font-size:12px;color:var(--admin-muted)">Tambahkan item / fitur yang akan di-invoice. Total di bawah otomatis terhitung.</p>
            <div class="wizard-line-items" data-line-items></div>
            <button type="button" class="wizard-line-add" data-add-line-item>＋ Tambah item</button>
            <div class="wizard-line-totals">
              <div class="wizard-line-totals-row">
                <span class="label">Total project</span>
                <span class="value" data-line-total>Rp0</span>
              </div>
            </div>
          </div>
        </div>

        <div class="wizard-panel" data-step-panel="4">
          <div class="wizard-panel-head">
            <h2>Termin pembayaran & dokumen</h2>
            <p>Bagi pembayaran per termin (opsional). Upload MOU / kontrak di sini. File bisa diedit setelah project dibuat.</p>
          </div>
          <h4 style="margin:0 0 10px;font-size:13px;font-weight:700;color:var(--admin-ink)">Termin / milestone</h4>
          <div class="wizard-milestones" data-milestones>
            <div class="wizard-milestone" data-milestone-row>
              <input name="milestone_title[]" placeholder="Termin 1 - DP 50%" />
              <input name="milestone_due[]" type="date" />
              <input name="milestone_amount[]" inputmode="numeric" data-money placeholder="Nominal" />
              <select name="milestone_status[]">
                <option value="pending">Pending</option>
                <option value="on-progress">On progress</option>
                <option value="completed">Completed</option>
                <option value="late">Late</option>
              </select>
              <button type="button" class="wizard-milestone-remove" data-remove-row title="Hapus">×</button>
            </div>
          </div>
          <button type="button" class="wizard-line-add" data-add-milestone>＋ Tambah termin</button>

          <h4 style="margin:24px 0 10px;font-size:13px;font-weight:700;color:var(--admin-ink)">Dokumen (MOU / kontrak)</h4>
          <label class="wizard-upload-zone" data-upload-zone>
            <input type="file" multiple accept="application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,image/png,image/jpeg,image/webp" data-upload-input />
            <div class="wizard-upload-zone-text">Klik atau drop file di sini · <strong>PDF, DOC, atau gambar</strong> · max 4MB</div>
          </label>
          <div class="wizard-upload-list" data-upload-list></div>
        </div>

        <div class="wizard-panel" data-step-panel="5">
          <div class="wizard-panel-head">
            <h2>Review & generate invoice</h2>
            <p>Cek ringkasan project di bawah. Klik "Simpan & buka invoice" untuk generate invoice siap kirim ke client.</p>
          </div>
          <div class="wizard-review-section" data-review-info></div>
          <div class="wizard-review-section" data-review-pricing></div>
          <div class="wizard-review-section" data-review-milestones></div>
        </div>

        <div class="wizard-actions">
          <button type="button" class="admin-button ghost" data-wizard-cancel>✕ Batal</button>
          <div class="wizard-actions-right">
            <button type="button" class="admin-button ghost" data-step-prev hidden>← Sebelumnya</button>
            <button type="button" class="admin-button accent" data-step-next>Selanjutnya →</button>
            <button type="submit" class="admin-button accent" data-step-submit hidden>Simpan & buka invoice ✓</button>
          </div>
        </div>
      </form>
    </section>
  </div>

  <script is:inline>
    window.addEventListener("DOMContentLoaded", () => {
      const esc = (value) => String(value ?? "").replace(/[&<>"']/g, (c) => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"}[c]));
      const money = (value) => window.formatRupiah(Number(value || 0));
      const moneyNumber = (value) => {
        if (typeof value === "number") return value;
        const text = String(value ?? "").trim();
        if (!text) return 0;
        if (/^\d+(\.\d+)?$/.test(text)) return Number(text);
        return Number(text.replace(/[^\d]/g, "")) || 0;
      };
      const moneyInput = (value) => String(Math.round(moneyNumber(value))).replace(/\B(?=(\d{3})+(?!\d))/g, ".");
      const cleanMoney = (value) => String(value ?? "").replace(/[^\d]/g, "");
      const iso = (value) => value ? String(value).slice(0, 10) : "";
      const today = () => new Date().toISOString().slice(0, 10);
      const statusLabel = (s) => ({ active: "on progress", "on-hold": "on hold", unpaid: "belum bayar", paid: "lunas" }[s] || s);
      const list = document.querySelector("[data-project-list]");
      let items = [];
      const state = { current: 1, projectId: null, uploads: [] };

      const wizardHost = document.querySelector("[data-wizard-host]");
      const wizardForm = document.querySelector("[data-wizard-form]");
      const progressBar = document.querySelector("[data-wizard-bar]");
      const stepPrev = document.querySelector("[data-step-prev]");
      const stepNext = document.querySelector("[data-step-next]");
      const stepSubmit = document.querySelector("[data-step-submit]");

      const setupMoneyInputs = (root) => {
        (root || document).querySelectorAll("[data-money]").forEach((input) => {
          if (input.dataset.moneyBound) return;
          input.dataset.moneyBound = "1";
          input.addEventListener("input", () => {
            const raw = cleanMoney(input.value);
            input.value = raw ? moneyInput(raw) : "";
            if (input.closest("[data-pricing-items]")) recalcLineTotal();
          });
        });
      };

      const recalcLineTotal = () => {
        let total = 0;
        document.querySelectorAll("[data-line-items] [data-line-row]").forEach((row) => {
          const qty = Number(row.querySelector("[data-line-qty]")?.value || 0);
          const price = Number(cleanMoney(row.querySelector("[data-line-price]")?.value) || 0);
          const sub = qty * price;
          row.querySelector("[data-line-subtotal]").textContent = money(sub);
          total += sub;
        });
        const totalEl = document.querySelector("[data-line-total]");
        if (totalEl) totalEl.textContent = money(total);
        return total;
      };

      const addLineItem = (prefill = {}) => {
        const container = document.querySelector("[data-line-items]");
        const row = document.createElement("div");
        row.className = "wizard-line-item";
        row.dataset.lineRow = "";
        row.innerHTML = `
          <input data-line-desc placeholder="Deskripsi item / fitur" value="${esc(prefill.description || "")}" />
          <input data-line-qty type="number" min="0" step="0.5" value="${esc(prefill.quantity ?? 1)}" placeholder="Qty" />
          <input data-line-price inputmode="numeric" data-money placeholder="Harga satuan" value="${prefill.unit_price ? moneyInput(prefill.unit_price) : ""}" />
          <span class="wizard-line-subtotal" data-line-subtotal>${money((Number(prefill.quantity || 1)) * Number(prefill.unit_price || 0))}</span>
          <button type="button" class="wizard-line-item-remove" data-remove-line title="Hapus">×</button>
        `;
        container.appendChild(row);
        setupMoneyInputs(row);
        row.querySelector("[data-remove-line]").addEventListener("click", () => { row.remove(); recalcLineTotal(); });
        recalcLineTotal();
      };

      const addMilestone = (prefill = {}) => {
        const container = document.querySelector("[data-milestones]");
        const row = document.createElement("div");
        row.className = "wizard-milestone";
        row.dataset.milestoneRow = "";
        row.innerHTML = `
          <input name="milestone_id[]" type="hidden" value="${esc(prefill.id || "")}" />
          <input name="milestone_title[]" placeholder="Termin ${container.children.length + 1}" value="${esc(prefill.title || "")}" />
          <input name="milestone_due[]" type="date" value="${esc(prefill.due_date || "")}" />
          <input name="milestone_amount[]" inputmode="numeric" data-money placeholder="Nominal" value="${prefill.amount ? moneyInput(prefill.amount) : ""}" />
          <select name="milestone_status[]">
            <option value="pending" ${prefill.status === "pending" || !prefill.status ? "selected" : ""}>Pending</option>
            <option value="on-progress" ${prefill.status === "on-progress" ? "selected" : ""}>On progress</option>
            <option value="completed" ${prefill.status === "completed" ? "selected" : ""}>Completed</option>
            <option value="late" ${prefill.status === "late" ? "selected" : ""}>Late</option>
          </select>
          <button type="button" class="wizard-milestone-remove" data-remove-row title="Hapus">×</button>
        `;
        container.appendChild(row);
        setupMoneyInputs(row);
        row.querySelector("[data-remove-row]").addEventListener("click", () => row.remove());
      };

      const setStep = (n) => {
        state.current = Math.max(1, Math.min(5, n));
        document.querySelectorAll("[data-step-panel]").forEach((p) => p.classList.toggle("active", Number(p.dataset.stepPanel) === state.current));
        document.querySelectorAll("[data-step-indicator]").forEach((s) => {
          const idx = Number(s.dataset.stepIndicator);
          s.classList.toggle("active", idx === state.current);
          s.classList.toggle("completed", idx < state.current);
        });
        if (progressBar) progressBar.style.width = `${((state.current - 1) / 4) * 64}%`;
        if (stepPrev) stepPrev.hidden = state.current === 1;
        if (stepNext) stepNext.hidden = state.current === 5;
        if (stepSubmit) stepSubmit.hidden = state.current !== 5;
        if (state.current === 5) renderReview();
        wizardForm.scrollIntoView({ behavior: "smooth", block: "start" });
      };

      const validateStep = (n) => {
        const data = new FormData(wizardForm);
        if (n === 1) {
          if (!cleanStr(data.get("name"))) return "Nama project wajib diisi.";
          if (!data.get("start_date")) return "Tanggal mulai wajib diisi.";
          if (!data.get("deadline")) return "Deadline wajib diisi.";
        }
        if (n === 3) {
          const model = data.get("pricing_model");
          if (model === "fixed") {
            const budget = Number(cleanMoney(data.get("budget")));
            if (!budget) return "Nominal total project wajib diisi.";
          } else {
            const lineTotal = recalcLineTotal();
            if (lineTotal <= 0) return "Tambahkan minimal satu item dengan harga.";
          }
        }
        return null;
      };

      const cleanStr = (v) => String(v ?? "").trim();

      const openWizard = (project = null) => {
        wizardHost.hidden = false;
        wizardForm.reset();
        state.uploads = [];
        renderUploadList();
        state.projectId = project?.id || null;
        wizardForm.elements.id.value = project?.id || "";
        if (project) {
          Object.entries(project).forEach(([key, value]) => {
            if (wizardForm.elements[key]) wizardForm.elements[key].value = wizardForm.elements[key].matches?.("[data-money]") ? moneyInput(value) : (["start_date", "deadline"].includes(key) ? iso(value) : value ?? "");
          });
          if (project.line_items?.length) {
            document.querySelector("[data-line-items]").innerHTML = "";
            project.line_items.forEach((it) => addLineItem(it));
            document.querySelector("[data-pricing-card='line_items']").click();
          } else {
            document.querySelector("[data-line-items]").innerHTML = "";
            document.querySelector("[data-pricing-card='fixed']").click();
          }
          document.querySelector("[data-milestones]").innerHTML = "";
          if (project.milestones?.length) project.milestones.forEach((m) => addMilestone(m));
          else addMilestone();
          const docs = (project.documents || []).filter((d) => !["invoice", "receipt", "general_invoice"].includes(d.document_type));
          state.uploads = docs.map((d) => ({ title: d.title, file_url: d.file_url, document_type: d.document_type, status: d.status, id: d.id }));
          renderUploadList();
        } else {
          document.querySelector("[data-line-items]").innerHTML = "";
          document.querySelector("[data-milestones]").innerHTML = "";
          addMilestone();
          wizardForm.elements.start_date.value = today();
          const dl = new Date(); dl.setDate(dl.getDate() + 30);
          wizardForm.elements.deadline.value = dl.toISOString().slice(0, 10);
        }
        setupMoneyInputs();
        recalcLineTotal();
        setStep(1);
        wizardHost.scrollIntoView({ behavior: "smooth", block: "start" });
      };

      const closeWizard = () => {
        wizardHost.hidden = true;
        state.projectId = null;
      };

      const renderUploadList = () => {
        const listEl = document.querySelector("[data-upload-list]");
        if (!state.uploads.length) { listEl.innerHTML = ""; return; }
        listEl.innerHTML = state.uploads.map((u, i) => `<div class="wizard-upload-item">
          <span>📄 <strong>${esc(u.title)}</strong>${u.file_url ? ` · <a href="${esc(u.file_url)}" target="_blank" rel="noreferrer">buka</a>` : ""}</span>
          <button type="button" class="wizard-upload-item-remove" data-upload-remove="${i}">×</button>
        </div>`).join("");
        listEl.querySelectorAll("[data-upload-remove]").forEach((btn) => {
          btn.addEventListener("click", () => { state.uploads.splice(Number(btn.dataset.uploadRemove), 1); renderUploadList(); });
        });
      };

      const uploadFile = async (file) => {
        const response = await fetch(`/api/admin/upload?filename=${encodeURIComponent(file.name)}`, { method: "POST", credentials: "same-origin", headers: { "Content-Type": file.type }, body: file });
        const data = await response.json().catch(() => ({}));
        if (!response.ok) throw new Error(data.message || "Upload gagal.");
        return data.url;
      };

      const renderReview = () => {
        const data = new FormData(wizardForm);
        const model = data.get("pricing_model") || "fixed";
        const milestones = collectMilestones();
        const lineItems = collectLineItems();
        const total = model === "line_items" ? lineItems.reduce((s, i) => s + (Number(i.quantity) * Number(i.unit_price)), 0) : Number(cleanMoney(data.get("budget")));
        document.querySelector("[data-review-info]").innerHTML = `
          <h4>Informasi Project</h4>
          <div class="wizard-review-row"><span class="review-label">Nama</span><span class="review-value">${esc(data.get("name") || "—")}</span></div>
          <div class="wizard-review-row"><span class="review-label">Client</span><span class="review-value">${esc(data.get("client") || "—")} ${data.get("client_contact") ? `· ${esc(data.get("client_contact"))}` : ""}</span></div>
          <div class="wizard-review-row"><span class="review-label">Tipe</span><span class="review-value">${esc(data.get("project_type") || "—")}</span></div>
          <div class="wizard-review-row"><span class="review-label">Timeline</span><span class="review-value">${window.formatDate(data.get("start_date"))} → ${window.formatDate(data.get("deadline"))}</span></div>
          <div class="wizard-review-row"><span class="review-label">Developer</span><span class="review-value" style="text-align:right;max-width:60%">${esc((data.get("team_assignments") || "Belum diisi").split(/\n+/).filter(Boolean).slice(0, 2).join(" · "))}</span></div>
          <div class="wizard-review-row"><span class="review-label">Scope</span><span class="review-value" style="text-align:right;max-width:60%">${esc((data.get("scope") || "—").slice(0, 200))}${(data.get("scope") || "").length > 200 ? "…" : ""}</span></div>
        `;
        const pricingRows = model === "line_items"
          ? (lineItems.length ? lineItems.map((i) => `<div class="wizard-review-row"><span class="review-label">${esc(i.description)} (${i.quantity}x)</span><span class="review-value">${money(i.quantity * i.unit_price)}</span></div>`).join("") + `<div class="wizard-review-row" style="font-weight:700"><span class="review-label">Total</span><span class="review-value">${money(total)}</span></div>` : '<div class="admin-empty">Belum ada item.</div>')
          : `<div class="wizard-review-row"><span class="review-label">Fixed price</span><span class="review-value">${money(total)}</span></div>`;
        document.querySelector("[data-review-pricing]").innerHTML = `<h4>Harga (${model === "line_items" ? "Per Item" : "Fixed Price"})</h4>${pricingRows}`;
        const msHtml = milestones.length ? milestones.map((m, i) => `<div class="wizard-review-row"><span class="review-label">#${i + 1} ${esc(m.title)} ${m.due_date ? `· due ${window.formatDate(m.due_date)}` : ""}</span><span class="review-value">${money(m.amount)}</span></div>`).join("") : '<div class="admin-empty">Tidak ada termin — invoice full payment.</div>';
        document.querySelector("[data-review-milestones]").innerHTML = `<h4>Termin Pembayaran</h4>${msHtml}${state.uploads.length ? `<div class="wizard-review-row" style="margin-top:8px"><span class="review-label">Dokumen terlampir</span><span class="review-value">${state.uploads.length} file</span></div>` : ""}`;
      };

      const collectLineItems = () => {
        const rows = [];
        document.querySelectorAll("[data-line-items] [data-line-row]").forEach((row) => {
          const desc = row.querySelector("[data-line-desc]")?.value?.trim();
          if (!desc) return;
          rows.push({
            description: desc,
            quantity: Number(row.querySelector("[data-line-qty]")?.value || 0) || 1,
            unit_price: Number(cleanMoney(row.querySelector("[data-line-price]")?.value) || 0)
          });
        });
        return rows;
      };

      const collectMilestones = () => {
        const rows = [];
        const titles = wizardForm.querySelectorAll("[name='milestone_title[]']");
        titles.forEach((input) => {
          if (!input.value?.trim()) return;
          const row = input.closest("[data-milestone-row]");
          rows.push({
            id: row.querySelector("[name='milestone_id[]']")?.value || undefined,
            title: input.value.trim(),
            due_date: row.querySelector("[name='milestone_due[]']").value || null,
            amount: Number(cleanMoney(row.querySelector("[name='milestone_amount[]']").value) || 0),
            status: row.querySelector("[name='milestone_status[]']").value
          });
        });
        return rows;
      };

      const collectProject = () => {
        const data = Object.fromEntries(new FormData(wizardForm));
        wizardForm.querySelectorAll("[data-money]").forEach((input) => {
          if (!input.name || input.name.endsWith("[]")) return;
          data[input.name] = cleanMoney(input.value);
        });
        const model = data.pricing_model || "fixed";
        return {
          id: data.id || undefined,
          name: data.name,
          client: data.client,
          client_contact: data.client_contact,
          client_address: data.client_address,
          project_type: data.project_type,
          status: data.status,
          start_date: data.start_date,
          deadline: data.deadline,
          notes: data.notes,
          scope: data.scope,
          features: data.features,
          team_assignments: data.team_assignments,
          pricing_model: model,
          budget: model === "fixed" ? data.budget : 0,
          line_items: model === "line_items" ? collectLineItems() : []
        };
      };

      // Event bindings
      document.querySelectorAll("[data-open-wizard]").forEach((b) => b.addEventListener("click", () => openWizard()));
      document.querySelector("[data-wizard-cancel]").addEventListener("click", async () => {
        const ok = await window.adminConfirm({
          title: "Tutup wizard?",
          message: "Data yang belum disimpan akan hilang.",
          confirmText: "Tutup wizard"
        });
        if (ok) closeWizard();
      });
      document.querySelector("[data-step-prev]").addEventListener("click", () => setStep(state.current - 1));
      document.querySelector("[data-step-next]").addEventListener("click", () => {
        const err = validateStep(state.current);
        if (err) { window.showAdminToast(err, "error"); return; }
        setStep(state.current + 1);
      });

      document.querySelectorAll("[data-pricing-card]").forEach((card) => {
        card.addEventListener("click", () => {
          document.querySelectorAll("[data-pricing-card]").forEach((c) => c.classList.remove("selected"));
          card.classList.add("selected");
          const isFixed = card.dataset.pricingCard === "fixed";
          document.querySelector("[data-pricing-fixed]").hidden = !isFixed;
          document.querySelector("[data-pricing-items]").hidden = isFixed;
          if (!isFixed && !document.querySelector("[data-line-items] [data-line-row]")) addLineItem();
        });
      });

      document.querySelector("[data-add-line-item]").addEventListener("click", () => addLineItem());
      document.querySelector("[data-add-milestone]").addEventListener("click", () => addMilestone());
      document.querySelectorAll("[data-remove-row]").forEach((b) => b.addEventListener("click", (e) => e.target.closest("[data-milestone-row]")?.remove()));

      document.querySelector("[data-upload-zone]").addEventListener("click", () => document.querySelector("[data-upload-input]").click());
      document.querySelector("[data-upload-input]").addEventListener("change", async (event) => {
        const files = Array.from(event.target.files || []);
        for (const file of files) {
          try {
            window.showAdminToast(`Uploading ${file.name}...`);
            const url = await uploadFile(file);
            state.uploads.push({ title: file.name, file_url: url, document_type: "mou", status: "draft" });
            renderUploadList();
          } catch (error) { window.showAdminToast(error.message, "error"); }
        }
        event.target.value = "";
      });

      wizardForm.addEventListener("submit", async (event) => {
        event.preventDefault();
        try {
          const payload = collectProject();
          const res = await window.adminApi("/api/admin/data?resource=projects", { method: "POST", body: JSON.stringify(payload) });
          const projectId = res.id || payload.id;
          if (!projectId) throw new Error("Project ID tidak diterima.");
          const milestones = collectMilestones();
          await window.adminApi("/api/admin/data?resource=project_children_sync", {
            method: "POST",
            body: JSON.stringify({
              project_id: projectId,
              milestones,
              documents: state.uploads.map((u) => ({
                id: u.id || undefined,
                title: u.title,
                document_type: u.document_type,
                file_url: u.file_url,
                status: u.status,
                amount: u.amount,
                issued_date: u.issued_date,
                notes: u.notes
              }))
            })
          });
          await window.adminApi(`/api/admin/data?resource=regenerate_invoice&project_id=${encodeURIComponent(projectId)}`, { method: "GET" }).catch(() => {});
          window.showAdminToast("Project tersimpan. Membuka invoice...");
          closeWizard();
          await load();
          setTimeout(() => { window.location.href = `/dashboard/invoice?project=${encodeURIComponent(projectId)}`; }, 600);
        } catch (error) { window.showAdminToast(error.message, "error"); }
      });

      // Project list
      const totals = () => {
        const sum = (key) => items.reduce((t, i) => t + Number(i[key] || 0), 0);
        document.querySelector("[data-project-booked]").textContent = money(sum("effective_budget"));
        document.querySelector("[data-project-received]").textContent = money(sum("payment_received"));
        document.querySelector("[data-project-outstanding]").textContent = money(sum("outstanding"));
        document.querySelector("[data-project-profit]").textContent = money(items.reduce((t, i) => t + Number(i.profit_actual || 0), 0));
      };
      const milestoneRows = (project) => project.milestones?.length ? project.milestones.map((m) => {
        const late = m.status !== "completed" && m.due_date && new Date(m.due_date) < new Date(today());
        return `<div class="ops-row ${late ? "late" : ""}"><div><strong>${esc(m.title)}</strong><span>${window.formatDate(m.due_date)} · ${money(m.amount)}</span></div><em>${late ? "late" : esc(m.status)}</em></div>`;
      }).join("") : '<div class="admin-empty">Belum ada termin.</div>';
      const documentRows = (project) => {
        const nonInvoice = (project.documents || []).filter((d) => !["invoice", "receipt", "general_invoice"].includes(d.document_type));
        const rows = nonInvoice.map((d) => `<div class="ops-row document-row"><div><strong>${esc(d.title)}</strong><span>${esc(d.document_type)} · ${window.formatDate(d.issued_date)}</span></div>${d.file_url ? `<a class="admin-button ghost" href="${esc(d.file_url)}" target="_blank" rel="noreferrer">Buka</a>` : ""}</div>`).join("");
        return rows || '<div class="admin-empty">Belum ada dokumen.</div>';
      };
      const render = () => {
        document.querySelector("[data-project-count]").textContent = `${items.length} project tercatat`;
        totals();
        if (!items.length) { list.innerHTML = '<div class="admin-empty">Belum ada project. Tambahkan project pertama di atas.</div>'; return; }
        list.innerHTML = items.map((item) => {
          return `<article class="project-command-card">
          <header>
            <div><span class="admin-badge ${esc(item.status)}">${esc(statusLabel(item.status))}</span><h3>${esc(item.name)}</h3><p>${esc(item.client || "Internal")} · ${window.formatDate(item.start_date)} - ${window.formatDate(item.deadline)}</p></div>
            <div class="admin-actions project-list-actions">
              <a class="admin-button accent" href="/dashboard/project?id=${encodeURIComponent(item.id)}">Detail</a>
              <a class="admin-button project-list-invoice-link" href="/dashboard/invoice?project=${encodeURIComponent(item.id)}" target="_blank" rel="noreferrer">📄 Invoice</a>
              <button class="admin-button ghost" data-edit-project="${esc(item.id)}">Edit</button>
              <button class="admin-button danger" data-delete-project="${esc(item.id)}">Hapus</button>
            </div>
          </header>
          <div class="project-money-grid">
            <div><small>${item.pricing_model === "line_items" ? "Total items" : "Harga project"}</small><strong>${money(item.effective_budget || item.budget)}</strong></div>
            <div><small>Pembayaran masuk</small><strong>${money(item.payment_received)}</strong></div>
            <div><small>Biaya operasional</small><strong>${money(item.operational_cost)}</strong></div>
            <div><small>Fee PIC</small><strong>${money(item.pic_fee)}</strong></div>
            <div><small>Profit aktual</small><strong>${money(item.profit_actual)}</strong></div>
            <div><small>Outstanding</small><strong>${money(item.outstanding)}</strong></div>
          </div>
          <div class="project-status-line"><div class="admin-progress"><span style="width:${Number(item.progress || 0)}%"></span></div><span>${Number(item.progress || 0)}%</span><em class="admin-badge ${esc(item.payment_status)}">${esc(statusLabel(item.payment_status))}</em></div>
          <div class="project-subgrid"><section><h4>Timeline termin</h4>${milestoneRows(item)}</section><section><h4>Dokumen</h4>${documentRows(item)}</section></div>
        </article>`;
        }).join("");
      };
      const load = async () => {
        const data = await window.adminApi("/api/admin/data?resource=projects");
        items = data.items || [];
        render();
      };
      list.addEventListener("click", async (event) => {
        const projectId = event.target.closest("[data-edit-project]")?.dataset.editProject;
        const deleteProject = event.target.closest("[data-delete-project]")?.dataset.deleteProject;
        if (projectId) { const item = items.find((i) => i.id === projectId); if (item) openWizard(item); }
        if (deleteProject && await window.adminConfirm({
          title: "Hapus project?",
          message: "Project, termin, dokumen, dan invoice terkait akan ikut terhapus.",
          confirmText: "Hapus project",
          danger: true
        })) {
          await window.adminApi("/api/admin/data?resource=projects", { method: "DELETE", body: JSON.stringify({ id: deleteProject }) });
          await load();
        }
      });
      list.addEventListener("input", (event) => {
        const form = event.target.closest("[data-progress-form]");
        if (!form) return;
        if (event.target.name === "progress") form.elements.progress_number.value = event.target.value;
        if (event.target.name === "progress_number") form.elements.progress.value = event.target.value;
      });
      list.addEventListener("submit", async (event) => {
        const form = event.target.closest("[data-progress-form]");
        if (!form) return;
        event.preventDefault();
        const payload = { id: form.dataset.progressForm, progress: form.elements.progress_number.value, status: form.elements.status.value };
        await window.adminApi("/api/admin/data?resource=project_progress", { method: "PUT", body: JSON.stringify(payload) });
        window.showAdminToast("Progress project diperbarui.");
        await load();
      });

      // Pre-fill from query string ?edit=...
      const params = new URLSearchParams(window.location.search);
      const editId = params.get("edit");
      if (editId) {
        window.adminApi(`/api/admin/data?resource=project&id=${encodeURIComponent(editId)}`)
          .then((data) => { if (data?.project) { items = [data.project, ...items]; openWizard(data.project); } })
          .catch(() => { /* silent */ });
      }

      setupMoneyInputs();
      load().catch((error) => { list.innerHTML = `<p class="admin-error">${esc(error.message)}</p>`; });
    });
  </script>
</DashboardLayout>
