---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---
<DashboardLayout title="Live Traffic" active="traffic" eyebrow="30-second pulse">
  <section class="admin-intro"><div><h2>Near-realtime tanpa koneksi mahal.</h2><p>Dashboard refresh otomatis setiap 30 detik. Visitor aktif dihitung dari sesi yang terlihat dalam lima menit terakhir.</p></div><span class="admin-badge" data-last-update>Menunggu data</span></section>
  <section class="admin-grid stats">
    <article class="admin-stat"><p class="admin-stat-label">Active visitors</p><div class="admin-stat-value" data-metric="active_visitors">0</div><span class="admin-stat-note">5 menit terakhir</span></article>
    <article class="admin-stat blue"><p class="admin-stat-label">Visits today</p><div class="admin-stat-value" data-metric="visits_today">0</div><span class="admin-stat-note">Pageviews hari ini</span></article>
    <article class="admin-stat coral"><p class="admin-stat-label">Unique sessions</p><div class="admin-stat-value" data-metric="unique_today">0</div><span class="admin-stat-note">Sesi unik hari ini</span></article>
  </section>
  <section class="admin-grid two" style="margin-top:16px">
    <article class="admin-panel admin-chart-panel"><div class="admin-panel-head"><div><h2>7-day traffic</h2><p>Tren pageviews harian</p></div><span class="chart-legend"><i></i> Pageviews</span></div><div class="admin-chart-wrap"><canvas data-traffic-chart></canvas></div></article>
    <article class="admin-panel"><div class="admin-panel-head"><div><h2>Landing/client page performance</h2><p>30 hari terakhir untuk evaluasi halaman utama dan project client</p></div></div><div class="traffic-list" data-page-performance></div></article>
    <article class="admin-panel"><div class="admin-panel-head"><div><h2>Top pages</h2><p>Tujuh hari terakhir</p></div></div><div class="traffic-list" data-top-pages></div></article>
    <article class="admin-panel"><div class="admin-panel-head"><div><h2>Referrers</h2><p>Sumber kunjungan teratas</p></div></div><div class="traffic-list" data-referrers></div></article>
    <article class="admin-panel"><div class="admin-panel-head"><div><h2>Latest visits</h2><p>Pageview terbaru</p></div></div><div class="traffic-list" data-latest></div></article>
  </section>
  <script>
    // @ts-nocheck -- browser dashboard data is validated by the authenticated API.
    import Chart from "chart.js/auto";
    window.addEventListener("DOMContentLoaded", () => {
      const esc = (value) => String(value ?? "").replace(/[&<>"']/g, (c) => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"}[c]));
      const animate = (node, next) => { const start = Number(node.textContent) || 0; const target = Number(next) || 0; const began = performance.now(); const tick = (now) => { const p = Math.min(1,(now-began)/550); node.textContent = Math.round(start+(target-start)*(1-Math.pow(1-p,3))).toLocaleString('id-ID'); if(p<1) requestAnimationFrame(tick); }; requestAnimationFrame(tick); };
      const rows = (items, labelKey, valueKey) => items.length ? items.map((item) => `<div class="traffic-row"><strong title="${esc(item[labelKey])}">${esc(item[labelKey])}</strong><span>${esc(item[valueKey])}</span></div>`).join("") : '<div class="admin-empty">Belum ada data.</div>';
      const context = document.querySelector("[data-traffic-chart]").getContext("2d");
      const gradient = context.createLinearGradient(0, 0, 0, 280);
      gradient.addColorStop(0, "rgba(2,62,138,.24)"); gradient.addColorStop(1, "rgba(2,62,138,0)");
      const trafficChart = new Chart(context, { type: "line", data: { labels: [], datasets: [{ label: "Pageviews", data: [], borderColor: "#023e8a", backgroundColor: gradient, borderWidth: 3, pointRadius: 3, pointHoverRadius: 6, pointBackgroundColor: "#d7ff3f", pointBorderColor: "#023e8a", pointBorderWidth: 2, fill: true, tension: .38 }] }, options: { responsive: true, maintainAspectRatio: false, interaction: { intersect: false, mode: "index" }, animation: { duration: 750, easing: "easeOutQuart" }, plugins: { legend: { display: false }, tooltip: { backgroundColor: "#071526", padding: 12, displayColors: false, titleFont: { family: "Plus Jakarta Sans", size: 10 }, bodyFont: { family: "Plus Jakarta Sans", size: 11, weight: "bold" } } }, scales: { x: { grid: { display: false }, border: { display: false }, ticks: { color: "#6d7785", font: { family: "Plus Jakarta Sans", size: 9, weight: 600 } } }, y: { beginAtZero: true, suggestedMax: 5, border: { display: false }, grid: { color: "rgba(7,21,38,.07)" }, ticks: { precision: 0, color: "#6d7785", font: { family: "Plus Jakarta Sans", size: 9 } } } } } });
      const load = async () => { try { const data = await window.adminApi("/api/admin/traffic"); Object.entries(data.summary).forEach(([key,value]) => { const node=document.querySelector(`[data-metric="${key}"]`); if(node) animate(node,value); }); trafficChart.data.labels = data.trend.map((d) => new Intl.DateTimeFormat('id-ID',{weekday:'short',day:'numeric'}).format(new Date(d.day))); trafficChart.data.datasets[0].data = data.trend.map((d) => Number(d.visits)); trafficChart.update(); document.querySelector("[data-page-performance]").innerHTML=data.pagePerformance.length?data.pagePerformance.map((item)=>`<div class="traffic-row"><strong title="${esc(item.path)}">${esc(item.path)}<br><span>${Number(item.sessions).toLocaleString('id-ID')} sessions · last ${new Intl.DateTimeFormat('id-ID',{day:'2-digit',month:'short'}).format(new Date(item.last_visit))}</span></strong><span>${Number(item.visits).toLocaleString('id-ID')}</span></div>`).join(""):'<div class="admin-empty">Belum ada data halaman penting.</div>'; document.querySelector("[data-top-pages]").innerHTML=rows(data.topPages,'path','visits'); document.querySelector("[data-referrers]").innerHTML=rows(data.referrers,'source','visits'); document.querySelector("[data-latest]").innerHTML=data.latest.length?data.latest.map((item)=>`<div class="traffic-row"><strong>${esc(item.path)}</strong><span>${new Intl.DateTimeFormat('id-ID',{hour:'2-digit',minute:'2-digit'}).format(new Date(item.created_at))}</span></div>`).join(''):'<div class="admin-empty">Belum ada kunjungan.</div>'; document.querySelector("[data-last-update]").textContent=`Update ${new Date().toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit',second:'2-digit'})}`; } catch(error) { window.showAdminToast(error.message,"error"); } };
      load(); window.setInterval(load,30000);
    });
  </script>
</DashboardLayout>
