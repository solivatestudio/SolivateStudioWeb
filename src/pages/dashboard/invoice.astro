---
import DashboardLayout from "../../layouts/DashboardLayout.astro";
---
<DashboardLayout title="Invoice" active="projects" eyebrow="Invoice generator">
  <section class="admin-intro">
    <div>
      <h2>Invoice siap kirim ke client.</h2>
      <p>Logo Solivate, info project, item / fitur, termin pembayaran, dan status pelunasan. Klik "Print" untuk save sebagai PDF lewat dialog browser.</p>
    </div>
    <a class="admin-button ghost" href="/dashboard/projects">← Kembali ke project</a>
  </section>

  <div class="invoice-toolbar" data-invoice-toolbar>
    <div>
      <strong data-invoice-number>Memuat invoice...</strong>
      <p data-invoice-subtitle style="margin:2px 0 0;font-size:12px;color:var(--admin-muted)"></p>
    </div>
    <div class="invoice-toolbar-actions">
      <button class="admin-button ghost" type="button" data-invoice-regenerate>↻ Regenerate</button>
      <a class="admin-button ghost" target="_blank" rel="noreferrer" data-invoice-edit>Edit project</a>
      <button class="admin-button accent" type="button" data-invoice-print>🖨 Print / Save PDF</button>
    </div>
  </div>

  <article class="invoice-page" data-invoice-page>
    <div class="invoice-empty">Memuat invoice...</div>
  </article>

  <script>
    // @ts-nocheck -- dashboard auth + dynamic invoice payload
    const esc = (value) => String(value ?? "").replace(/[&<>"']/g, (c) => ({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#039;"}[c]));
    const money = (value) => window.formatRupiah(Number(value || 0));
    const dateOnly = (value) => value ? new Intl.DateTimeFormat("id-ID", { day: "2-digit", month: "long", year: "numeric" }).format(new Date(value)) : "-";

    function statusBadge(status) {
      const label = { paid: "Lunas", dp: "DP / Sebagian", pending: "Belum Dibayar" }[status] || status;
      return `<span class="invoice-status-badge ${esc(status)}">${esc(label)}</span>`;
    }

    function renderEmpty(message) {
      const page = document.querySelector("[data-invoice-page]");
      page.innerHTML = `<div class="invoice-empty">${esc(message)}</div>`;
      document.querySelector("[data-invoice-number]").textContent = "Invoice tidak ditemukan";
      document.querySelector("[data-invoice-subtitle]").textContent = "";
      const editLink = document.querySelector("[data-invoice-edit]");
      if (editLink) editLink.style.display = "none";
    }

    function renderLineItemsTable(items) {
      if (!items?.length) {
        return `<tr><td colspan="4" style="text-align:center;padding:24px;color:#6d7785">Tidak ada item terdefinisi.</td></tr>`;
      }
      return items.map((item) => `<tr>
        <td>${esc(item.description)}</td>
        <td>${Number(item.quantity || 1)}</td>
        <td>${money(item.unit_price)}</td>
        <td><strong>${money(Number(item.quantity || 1) * Number(item.unit_price || 0))}</strong></td>
      </tr>`).join("");
    }

    function renderMilestones(milestones) {
      if (!milestones?.length) {
        return `<div class="admin-empty">Tidak ada termin pembayaran terpisah — total project sekaligus.</div>`;
      }
      return `<div class="invoice-milestones-list">${milestones.map((m, i) => `<div class="invoice-milestone-row">
        <span class="ms-index">#${i + 1}</span>
        <span class="ms-title">${esc(m.title)} <span style="font-size:11px;color:#6d7785;margin-left:6px">${esc(m.status || "")}</span></span>
        <span class="ms-amount">${money(m.amount)}</span>
        <span class="ms-date">${m.due_date ? `Due ${dateOnly(m.due_date)}` : "-"}</span>
      </div>`).join("")}</div>`;
    }

    function renderInvoice(payload, project) {
      const page = document.querySelector("[data-invoice-page]");
      const items = payload.line_items || [];
      const milestones = payload.milestones || [];
      const lineItemsHtml = renderLineItemsTable(items);
      const milestonesHtml = renderMilestones(milestones);
      const showLineItems = items.length > 0;
      const subTotalRows = showLineItems
        ? `<div class="invoice-totals-row"><span>Subtotal item</span><strong>${money(payload.subtotal)}</strong></div>`
        : "";

      page.innerHTML = `
        <header class="invoice-header">
          <div class="invoice-header-brand">
            <img src="${esc(payload.logo_url || "/solivate-logo.webp")}" alt="${esc(payload.provider?.name || "Logo")}" onerror="this.onerror=null;this.src='/solivate-logo.webp'" />
            <span class="invoice-tagline">${esc(payload.tagline || "")}</span>
          </div>
          <div class="invoice-header-meta">
            <h1>${esc(payload.document_title || "INVOICE").toUpperCase()}</h1>
            <div class="invoice-number">No: ${esc(payload.invoice_number)}</div>
            <div style="margin-top:8px">${statusBadge(payload.status)}</div>
          </div>
        </header>

        <section class="invoice-parties">
          <div class="invoice-party">
            <h4>${payload.document_kind === "receipt" ? "Dibayarkan oleh" : "Dari"}</h4>
            <div class="invoice-party-name">${esc(payload.provider?.name || "Solivate Studio")}</div>
            <p>${esc(payload.provider?.address || "Indonesia")}</p>
            <p>${esc(payload.provider?.email || "")}</p>
            <p>${esc(payload.provider?.phone || "")}</p>
          </div>
          <div class="invoice-party">
            <h4>${payload.document_kind === "receipt" ? "Kepada (Vendor / Penerima)" : "Kepada (Client)"}</h4>
            <div class="invoice-party-name">${esc(payload.client?.name || "—")}</div>
            <p>${esc(payload.client?.address || "—")}</p>
            <p>${esc(payload.client?.contact || "")}</p>
          </div>
        </section>

        <section class="invoice-dates">
          <div class="invoice-date-block">
            <div class="invoice-date-label">Tanggal Invoice</div>
            <div class="invoice-date-value">${dateOnly(payload.issued_date)}</div>
          </div>
          <div class="invoice-date-block">
            <div class="invoice-date-label">Jatuh Tempo</div>
            <div class="invoice-date-value">${dateOnly(payload.due_date)}</div>
          </div>
          <div class="invoice-date-block">
            <div class="invoice-date-label">${project ? "Project" : (payload.category ? "Kategori" : "Referensi")}</div>
            <div class="invoice-date-value">${esc(payload.project?.name || (project ? project.name : (payload.category || "—")))}</div>
          </div>
        </section>

        <section class="invoice-section">
          <h3>${showLineItems ? (project ? "Item / Fitur" : "Item") : (project ? "Deskripsi Project" : "Deskripsi")}</h3>
          ${showLineItems
            ? `<table class="invoice-table">
                <thead><tr><th>Deskripsi</th><th>Qty</th><th>Harga Satuan</th><th>Subtotal</th></tr></thead>
                <tbody>${lineItemsHtml}</tbody>
              </table>
              <div class="invoice-totals">
                <div class="invoice-totals-box">
                  ${subTotalRows}
                  <div class="invoice-totals-row grand"><span>TOTAL</span><strong>${money(payload.total)}</strong></div>
                  ${payload.received > 0 ? `<div class="invoice-totals-row" style="margin-top:8px"><span>Sudah dibayar</span><strong style="color:#065f46">${money(payload.received)}</strong></div>` : ""}
                  ${payload.balance > 0 ? `<div class="invoice-totals-row"><span>Sisa</span><strong style="color:#dc2626">${money(payload.balance)}</strong></div>` : ""}
                </div>
              </div>`
            : `<div class="invoice-scope">${esc(payload.project?.scope || project.scope || "—")}</div>
              <div class="invoice-totals">
                <div class="invoice-totals-box">
                  <div class="invoice-totals-row grand"><span>TOTAL PROJECT</span><strong>${money(payload.total)}</strong></div>
                  ${payload.received > 0 ? `<div class="invoice-totals-row" style="margin-top:8px"><span>Sudah dibayar</span><strong style="color:#065f46">${money(payload.received)}</strong></div>` : ""}
                  ${payload.balance > 0 ? `<div class="invoice-totals-row"><span>Sisa</span><strong style="color:#dc2626">${money(payload.balance)}</strong></div>` : ""}
                </div>
              </div>`
          }
        </section>

        ${milestones.length && project ? `<section class="invoice-section">
          <h3>Termin Pembayaran</h3>
          ${milestonesHtml}
        </section>` : ""}

        <section class="invoice-section">
          <h3>${project ? "Catatan" : "Catatan"}</h3>
          <div class="invoice-scope">${esc(payload.footer_note || payload.project?.notes || payload.project?.scope || "")}</div>
        </section>

        <footer class="invoice-footer">
          <div class="invoice-footer-block">
            <h5>Informasi Pembayaran</h5>
            <p>Bank: ${esc(payload.bank?.name || "—")}</p>
            <p>No. Rekening: ${esc(payload.bank?.account_number || "—")}</p>
            <p>Atas nama: ${esc(payload.bank?.account_name || "—")}</p>
          </div>
          <div class="invoice-footer-block">
            <h5>Kontak</h5>
            <p>${esc(payload.provider?.email || "")}</p>
            <p>${esc(payload.provider?.phone || "")}</p>
            <p>${esc(payload.provider?.website || "")}</p>
          </div>
        </footer>
      `;

      document.querySelector("[data-invoice-number]").textContent = `Invoice ${payload.invoice_number}`;
      document.querySelector("[data-invoice-subtitle]").textContent = `${payload.client?.name || ""} · ${payload.project?.name || payload.category || ""} · ${money(payload.total)}`;
      const editLink = document.querySelector("[data-invoice-edit]");
      if (editLink) {
        if (project?.id) {
          editLink.href = `/dashboard/projects?edit=${encodeURIComponent(project.id)}`;
          editLink.style.display = "";
        } else {
          editLink.href = "/dashboard/finance";
          editLink.textContent = "Lihat finance →";
        }
      }
    }

    function getProjectId() {
      const params = new URLSearchParams(window.location.search);
      return params.get("project");
    }
    function getDocId() {
      const params = new URLSearchParams(window.location.search);
      return params.get("doc");
    }

    async function loadInvoice() {
      const docId = getDocId();
      const projectId = getProjectId();
      if (!docId && !projectId) {
        renderEmpty("Pilih project atau invoice dari daftar untuk membuka invoice.");
        return;
      }
      try {
        const url = docId
          ? `/api/admin/data?resource=invoice&doc_id=${encodeURIComponent(docId)}`
          : `/api/admin/data?resource=invoice&project_id=${encodeURIComponent(projectId)}`;
        const data = await window.adminApi(url);
        if (!data || !data.payload) {
          renderEmpty("Invoice belum tersedia.");
          return;
        }
        renderInvoice(data.payload, data.project);
      } catch (error) {
        renderEmpty(error.message || "Gagal memuat invoice.");
        window.showAdminToast?.(error.message, "error");
      }
    }

    document.querySelector("[data-invoice-print]")?.addEventListener("click", () => window.print());
    document.querySelector("[data-invoice-regenerate]")?.addEventListener("click", async () => {
      const docId = getDocId();
      const projectId = getProjectId();
      try {
        if (docId) {
          const financeId = docId.replace("general-invoice-", "");
          await window.adminApi(`/api/admin/data?resource=regenerate_general_invoice&finance_id=${encodeURIComponent(financeId)}`);
        } else if (projectId) {
          await window.adminApi(`/api/admin/data?resource=regenerate_invoice&project_id=${encodeURIComponent(projectId)}`);
        }
        window.showAdminToast?.("Invoice di-regenerate.");
        await loadInvoice();
      } catch (error) {
        window.showAdminToast?.(error.message, "error");
      }
    });

    window.addEventListener("DOMContentLoaded", loadInvoice);
  </script>
</DashboardLayout>
