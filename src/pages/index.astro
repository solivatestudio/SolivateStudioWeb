  "success.reset": { id: "Kirim lagi", en: "Send another" },
  "footer.title": { id: "Bangun sesuatu yang orang ingat.", en: "Let's build something people remember." },
  "footer.cta": { id: "Mulai Proyek", en: "Start Project" },
