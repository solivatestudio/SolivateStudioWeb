    <Footer home i18n />

    <script is:inline type="application/ld+json" set:html={organizationSchema}></script>
    <script is:inline type="application/json" id="i18n-data" set:html={i18nJson}></script>
    <script is:inline>
      const translations = JSON.parse(document.getElementById("i18n-data")?.textContent || "{}");
      const header = document.querySelector("[data-header]");
      let cmsResources = {};

      const escapeHtml = (value) => String(value ?? "").replace(/[&<>"']/g, (char) => ({
        "&": "&amp;",
        "<": "&lt;",
        ">": "&gt;",
        "\"": "&quot;",
        "'": "&#039;"
      }[char]));
      const cmsText = (data, key, lang) => data?.[`${key}_${lang}`] || data?.[`${key}_id`] || data?.[key] || "";
      const cmsList = (data, key, lang) => Array.isArray(data?.[`${key}_${lang}`]) ? data[`${key}_${lang}`] : [];
      const enableFaqToggles = () => {
        document.querySelectorAll("[data-faq]").forEach((item) => {
          const button = item.querySelector("[data-faq-trigger]");
          const panel = item.querySelector("[data-faq-panel]");
          button?.addEventListener("click", () => {
            const open = panel?.hasAttribute("hidden");
            document.querySelectorAll("[data-faq-panel]").forEach((current) => current.setAttribute("hidden", ""));
            document.querySelectorAll("[data-faq-trigger]").forEach((current) => current.setAttribute("aria-expanded", "false"));
            if (open && panel) {
              panel.removeAttribute("hidden");
              button.setAttribute("aria-expanded", "true");
            }
          });
        });
      };
      const renderCmsResources = (lang = document.documentElement.lang || "id") => {
        const activeLang = lang === "en" ? "en" : "id";
        const pricing = (cmsResources.pricing || []).filter((item) => item.data?.homepage).slice(0, 3);
        const pricingGrid = document.querySelector(".pricing-grid");
        if (pricingGrid && pricing.length) {
          pricingGrid.innerHTML = pricing.map((item) => {
            const data = item.data || {};
            const featured = data.featured ? " featured" : "";
            const features = cmsList(data, "features", activeLang).slice(0, 4);
            return `<article class="pricing-card${featured}">
              <span class="pricing-label">${escapeHtml(cmsText(data, "badge", activeLang))}</span>
              <div class="card-title">${escapeHtml(cmsText(data, "name", activeLang))}</div>
              <strong>${escapeHtml(cmsText(data, "price", activeLang))}</strong>
              <p>${escapeHtml(cmsText(data, "description", activeLang))}</p>
              <ul>${features.map((feature) => `<li>${escapeHtml(feature)}</li>`).join("")}</ul>
            </article>`;
          }).join("");
        }

        const projects = (cmsResources.projects || []).filter((item) => item.data?.homepage).slice(0, 6);
        const workGrid = document.querySelector(".work-grid");
        if (workGrid && projects.length) {
          workGrid.innerHTML = projects.map((item, index) => {
            const data = item.data || {};
            const url = data.url || "#contact";
            const external = url.startsWith("http");
            return `<a class="work-card" data-project-card="${index + 1}" href="${escapeHtml(url)}" ${external ? 'target="_blank" rel="noreferrer"' : ""}>
              <img data-project-image src="${escapeHtml(data.image_url || "/solivate-logo.webp")}" alt="${escapeHtml(data.title)}" width="1440" height="900" loading="lazy" decoding="async" />
              <div>
                <span>${escapeHtml(cmsText(data, "type", activeLang))}</span>
                <p class="card-heading" data-project-title>${escapeHtml(data.title)}</p>
              </div>
            </a>`;
          }).join("");
        }

        const faqItems = (cmsResources.faq || []).slice(0, 6);
        const faqList = document.querySelector(".faq-list");
        if (faqList && faqItems.length) {
          faqList.innerHTML = faqItems.map((item, index) => {
            const data = item.data || {};
            return `<article class="faq-item" data-faq>
              <button type="button" data-faq-trigger aria-expanded="${index === 0 ? "true" : "false"}">
                <span>${escapeHtml(cmsText(data, "question", activeLang))}</span>
                <span class="chevron" aria-hidden="true"></span>
              </button>
              <p data-faq-panel ${index === 0 ? "" : "hidden"}>${escapeHtml(cmsText(data, "answer", activeLang))}</p>
            </article>`;
          }).join("");
          enableFaqToggles();
        }
      };

      const updateHeader = () => {
        const y = Math.max(0, window.scrollY);
        header?.classList.toggle("is-scrolled", y > 24);
        header?.classList.toggle("is-compact", y > 64);
      };

      const setLanguage = (lang, persist = false) => {
        const activeLang = lang === "en" ? "en" : "id";
        document.documentElement.lang = activeLang;
        if (persist) {
          window.localStorage.setItem("solivate-language", activeLang);
          window.localStorage.setItem("solivate-language-manual", "true");
        }

        document.querySelectorAll("[data-i18n]").forEach((node) => {
          const key = node.getAttribute("data-i18n");
          const next = translations[key]?.[activeLang];
          if (next) node.textContent = next;
        });

        document.querySelectorAll("[data-i18n-placeholder]").forEach((node) => {
          const key = node.getAttribute("data-i18n-placeholder");
          const next = translations[key]?.[activeLang];
          if (next) node.setAttribute("placeholder", next);
        });

        document.querySelectorAll("[data-lang-switch]").forEach((button) => {
          const active = button.getAttribute("data-lang-switch") === activeLang;
          button.classList.toggle("active", active);
          button.setAttribute("aria-pressed", String(active));
        });
        renderCmsResources(activeLang);
      };

      let ticking = false;
      window.addEventListener("scroll", () => {
        if (!ticking) {
          window.requestAnimationFrame(() => {
            updateHeader();
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
      updateHeader();
      window.addEventListener("load", updateHeader);
      window.addEventListener("hashchange", updateHeader);
      window.setTimeout(updateHeader, 120);

      document.querySelectorAll("[data-lang-switch]").forEach((button) => {
        button.addEventListener("click", () => setLanguage(button.getAttribute("data-lang-switch"), true));
      });
      const savedLanguage = window.localStorage.getItem("solivate-language-manual") === "true"
        ? window.localStorage.getItem("solivate-language")
        : "id";
      setLanguage(savedLanguage || "id");

      fetch("/api/public/cms")
        .then((response) => response.ok ? response.json() : null)
        .then((data) => {
          const entries = data?.entries || {};
          Object.keys(translations).forEach((translationKey) => {
            ["id", "en"].forEach((locale) => {
              const value = entries[`copy:${translationKey}:${locale}`];
              if (typeof value === "string" && value.trim()) translations[translationKey][locale] = value;
            });
          });
          const legacyMap = { "hero.title": "hero_title", "hero.text": "hero_text", "about.title": "about_title" };
          Object.entries(legacyMap).forEach(([translationKey, cmsKey]) => ["id", "en"].forEach((locale) => {
            const value = entries[`${cmsKey}_${locale}`];
            if (typeof value === "string" && value.trim() && !entries[`copy:${translationKey}:${locale}`]) translations[translationKey][locale] = value;
          }));
          document.querySelectorAll("[data-project-card]").forEach((card) => {
            const index = card.dataset.projectCard;
            const title = String(entries[`project:${index}:title`] || "").trim();
            const url = String(entries[`project:${index}:url`] || "").trim();
            const image = String(entries[`project:${index}:image`] || "").trim();
            const titleNode = card.querySelector("[data-project-title]");
            const imageNode = card.querySelector("[data-project-image]");
            if (title && titleNode) { titleNode.textContent = title; imageNode.alt = title; }
            if (url) { card.href = url; card.target = url.startsWith("http") ? "_blank" : ""; card.rel = url.startsWith("http") ? "noreferrer" : ""; }
            if (image && imageNode) imageNode.src = image;
          });
          setLanguage(document.documentElement.lang);
        })
        .catch(() => {});

      fetch("/api/public/content")
        .then((response) => response.ok ? response.json() : null)
        .then((data) => {
          cmsResources = data?.resources || {};
          renderCmsResources(document.documentElement.lang);
        })
        .catch(() => {});

      document.querySelectorAll("[data-scroll]").forEach((trigger) => {
        trigger.addEventListener("click", () => {
          const target = document.getElementById(trigger.getAttribute("data-scroll"));
          target?.scrollIntoView({ behavior: "smooth", block: "start" });
        });
      });

      document.querySelectorAll("[data-top]").forEach((trigger) => {
        trigger.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
      });

      enableFaqToggles();

      const contactForm = document.querySelector("[data-contact-form]");
      const success = document.querySelector("[data-success]");
      const formError = document.querySelector("[data-form-error]");
      const refreshStartedAt = () => {
        contactForm?.querySelector("[data-started-at]")?.setAttribute("value", String(Date.now()));
      };
      refreshStartedAt();
      contactForm?.addEventListener("submit", (event) => {
        event.preventDefault();
        formError?.setAttribute("hidden", "");
        if (formError) {
          formError.textContent = translations["form.error"]?.[document.documentElement.lang === "en" ? "en" : "id"] || formError.textContent;
        }
        if (!contactForm.querySelector("[data-started-at]")?.getAttribute("value")) {
          refreshStartedAt();
        }
        const formData = new FormData(contactForm);
        const submit = contactForm.querySelector('button[type="submit"]');
        const submitText = submit?.querySelector("[data-i18n]");
        const activeLang = document.documentElement.lang === "en" ? "en" : "id";
        const originalText = submitText?.textContent || "";

        submit?.setAttribute("disabled", "");
        if (submitText) submitText.textContent = translations["form.sending"]?.[activeLang] || "Mengirim...";

        fetch("/api/contact", {
          method: "POST",
          headers: {
            "Content-Type": "application/json"
          },
          body: JSON.stringify({
            name: formData.get("name"),
            contact: formData.get("contact"),
            projectType: formData.get("projectType"),
            brief: formData.get("brief"),
            website: formData.get("website"),
            startedAt: formData.get("startedAt"),
            turnstileToken: formData.get("cf-turnstile-response")
          })
        })
          .then(async (response) => {
            const data = await response.json().catch(() => ({}));
            if (!response.ok) {
              throw new Error(data.message || translations["form.error"]?.[activeLang] || "Brief belum terkirim.");
            }
            contactForm.setAttribute("hidden", "");
            success?.removeAttribute("hidden");
            contactForm.reset();
            window.turnstile?.reset();
          })
          .catch((error) => {
            window.turnstile?.reset();
            if (formError) {
              formError.textContent = error?.message || translations["form.error"]?.[activeLang] || "Brief belum terkirim.";
            }
            formError?.removeAttribute("hidden");
          })
          .finally(() => {
            submit?.removeAttribute("disabled");
            if (submitText) submitText.textContent = originalText;
          });
      });
      document.querySelector("[data-reset-form]")?.addEventListener("click", () => {
        success?.setAttribute("hidden", "");
        contactForm?.removeAttribute("hidden");
        refreshStartedAt();
      });

      if (!window.matchMedia("(hover: none)").matches) {
        document
          .querySelectorAll(".btn-primary, .btn-secondary, .nav-cta, .service-card, .pricing-card, .work-card, .feature-card, .process-grid article, .preview, .contact-card")
          .forEach((el) => {
            let frame = 0;
            const strength = el.matches(".btn-primary, .btn-secondary, .nav-cta") ? 0.12 : 0.035;

            el.addEventListener("mousemove", (event) => {
              const pointer = event;
              window.cancelAnimationFrame(frame);
              frame = window.requestAnimationFrame(() => {
                const rect = el.getBoundingClientRect();
                const x = (pointer.clientX - (rect.left + rect.width / 2)) * strength;
                const y = (pointer.clientY - (rect.top + rect.height / 2)) * strength;
                el.style.setProperty("--hover-x", `${x.toFixed(2)}px`);
                el.style.setProperty("--hover-y", `${y.toFixed(2)}px`);
              });
            });

            el.addEventListener("mouseleave", () => {
              window.cancelAnimationFrame(frame);
              el.style.setProperty("--hover-x", "0px");
              el.style.setProperty("--hover-y", "0px");
            });
          });
      }
    </script>
  </body>
</html>
