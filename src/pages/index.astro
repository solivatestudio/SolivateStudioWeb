        </div>
        <div class="container work-grid">
          {works.map((item, index) => (
            <a class="work-card" data-project-card={index + 1} href={item.url ?? "#contact"} target={item.url?.startsWith("http") ? "_blank" : undefined} rel={item.url?.startsWith("http") ? "noreferrer" : undefined}>
              <img data-project-image src={item.img} alt={item.title} width={item.width} height={item.height} loading="lazy" decoding="async" />
              <div>
                <span data-i18n={item.typeKey}>{tx(item.typeKey)}</span>
