<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content="Solivate Studio, jasa pembuatan website, jasa website UMKM, website company profile, website komunitas, website masjid, website event, website konser, wedding invitation, birthday website, website rental mobil, website barbershop, website panti asuhan, website custom, digital solution provider Bekasi" />
    <meta name="author" content="Solivate Studio" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={siteUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Solivate Studio" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:image" content={`${siteUrl}/solivate-logo.svg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={`${siteUrl}/solivate-logo.svg`} />
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body>
    <header class="header" data-header>
      <div class="wrap header-inner">
        <button class="brand header-brand" type="button" data-top aria-label="Kembali ke atas">
          <img src="/solivate-logo.svg" alt="Solivate Studio" width="9935" height="1285" />
        </button>

        <nav class="nav" aria-label="Navigasi utama">
          {navItems.map((item) => (
            <button
              class={`nav-link ${item.target === "about" ? "nav-link-primary" : ""}`}
              type="button"
              data-scroll={item.target}
            >
              <span data-i18n={item.key}>{tx(item.key)}</span>
            </button>
          ))}

          <button class="nav-cta" type="button" data-scroll="contact">
            <span class="nav-dot"></span>
            <span data-i18n="nav.cta">{tx("nav.cta")}</span>
            <svg class="arrow" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg>
          </button>

          <div class="language-toggle" aria-label="Pilih bahasa">
            <button class="active" type="button" data-lang-switch="id" aria-pressed="true">ID</button>
            <button type="button" data-lang-switch="en" aria-pressed="false">EN</button>
          </div>
        </nav>
      </div>
    </header>

    <main>
      <section class="hero">
        <div class="hero-bg"></div>
        <div class="container hero-grid">
          <div class="hero-copy">
            <div class="trust-row">
              <span class="avatar-stack">
                <i>SS</i>
                <i>UX</i>
                <i>FE</i>
              </span>
              <span class="stars" aria-hidden="true">
                {Array.from({ length: 5 }).map(() => <i></i>)}
              </span>
              <p data-i18n="hero.trust">{tx("hero.trust")}</p>
            </div>
            <h1 data-i18n="hero.title">{tx("hero.title")}</h1>
            <p class="hero-text" data-i18n="hero.text">{tx("hero.text")}</p>
            <div class="hero-actions">
              <button class="btn-primary" type="button" data-scroll="contact">
                <span data-i18n="hero.primary">{tx("hero.primary")}</span>
                <svg class="arrow" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg>
              </button>
              <button class="btn-secondary" type="button" data-scroll="work" data-i18n="hero.secondary">
                {tx("hero.secondary")}
              </button>
            </div>
          </div>

          <div class="preview">
            <div class="preview-top">
              <span></span>
              <span></span>
              <span></span>
              <p data-i18n="preview.url">{tx("preview.url")}</p>
            </div>
            <div class="preview-body">
              <div class="preview-sidebar">
                <span class="active"></span>
                <span></span>
                <span></span>
                <span></span>
              </div>
              <div class="preview-content">
                <div class="metric-card primary">
                  <small data-i18n="preview.velocity">{tx("preview.velocity")}</small>
                  <strong>2.4x</strong>
                  <div class="bar"><i></i></div>
                </div>
                <div class="metric-card">
                  <small data-i18n="preview.readiness">{tx("preview.readiness")}</small>
                  <strong>86%</strong>
                  <div class="mini-bars"><span></span><span></span><span></span></div>
                </div>
                <div class="timeline-card">
                  <small data-i18n="preview.map">{tx("preview.map")}</small>
                  <div><i></i><i></i><i></i><i></i></div>
                </div>
                <div class="image-card">
                  <img src="/images/portfolio_cloud_1781799732798.webp" alt="" loading="eager" />
                  <span data-i18n="preview.badge">{tx("preview.badge")}</span>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="marquee" aria-hidden="true">
          <div class="marquee-track">
            {Array.from({ length: 2 }).map((_, groupIndex) => (
              <div class="marquee-group">
                {marqueeItems.map((key, index) => (
                  <span>
                    <span class={(index + groupIndex) % 2 ? "muted" : ""} data-i18n={key}>{tx(key)}</span>
                    <i class="marquee-dot"></i>
                  </span>
                ))}
              </div>
            ))}
          </div>
