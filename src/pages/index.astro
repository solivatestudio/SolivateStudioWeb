    <script is:inline type="application/json" id="i18n-data" set:html={i18nJson}></script>
    <script is:inline>
      const translations = JSON.parse(document.getElementById("i18n-data")?.textContent || "{}");
      const header = document.querySelector("[data-header]");

      const updateHeader = () => {
        const y = Math.max(0, window.scrollY);
        header?.classList.toggle("is-scrolled", y > 24);
        header?.classList.toggle("is-compact", y > 64);
      };

      const setLanguage = (lang) => {
        const activeLang = lang === "en" ? "en" : "id";
        document.documentElement.lang = activeLang;
        window.localStorage.setItem("solivate-language", activeLang);

        document.querySelectorAll("[data-i18n]").forEach((node) => {
          const key = node.getAttribute("data-i18n");
          const next = translations[key]?.[activeLang];
          if (next) node.textContent = next;
        });

        document.querySelectorAll("[data-i18n-placeholder]").forEach((node) => {
          const key = node.getAttribute("data-i18n-placeholder");
          const next = translations[key]?.[activeLang];
          if (next) node.setAttribute("placeholder", next);
        });

        document.querySelectorAll("[data-lang-switch]").forEach((button) => {
          const active = button.getAttribute("data-lang-switch") === activeLang;
          button.classList.toggle("active", active);
          button.setAttribute("aria-pressed", String(active));
        });
      };

      let ticking = false;
      window.addEventListener("scroll", () => {
        if (!ticking) {
          window.requestAnimationFrame(() => {
            updateHeader();
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
      updateHeader();
      window.addEventListener("load", updateHeader);
      window.addEventListener("hashchange", updateHeader);
      window.setTimeout(updateHeader, 120);

      document.querySelectorAll("[data-lang-switch]").forEach((button) => {
        button.addEventListener("click", () => setLanguage(button.getAttribute("data-lang-switch")));
      });
      setLanguage(window.localStorage.getItem("solivate-language") || "id");

      document.querySelectorAll("[data-scroll]").forEach((trigger) => {
        trigger.addEventListener("click", () => {
          const target = document.getElementById(trigger.getAttribute("data-scroll"));
          target?.scrollIntoView({ behavior: "smooth", block: "start" });
        });
      });

      document.querySelectorAll("[data-top]").forEach((trigger) => {
        trigger.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
      });

      document.querySelectorAll("[data-faq]").forEach((item) => {
        const button = item.querySelector("[data-faq-trigger]");
        const panel = item.querySelector("[data-faq-panel]");
        button?.addEventListener("click", () => {
          const open = panel?.hasAttribute("hidden");
          document.querySelectorAll("[data-faq-panel]").forEach((current) => current.setAttribute("hidden", ""));
          document.querySelectorAll("[data-faq-trigger]").forEach((current) => current.setAttribute("aria-expanded", "false"));
          if (open && panel) {
            panel.removeAttribute("hidden");
            button.setAttribute("aria-expanded", "true");
          }
        });
      });

      const contactForm = document.querySelector("[data-contact-form]");
      const success = document.querySelector("[data-success]");
      contactForm?.addEventListener("submit", (event) => {
        event.preventDefault();
        contactForm.setAttribute("hidden", "");
        success?.removeAttribute("hidden");
      });
      document.querySelector("[data-reset-form]")?.addEventListener("click", () => {
        success?.setAttribute("hidden", "");
        contactForm?.removeAttribute("hidden");
      });

      if (!window.matchMedia("(hover: none)").matches) {
        document
          .querySelectorAll(".btn-primary, .btn-secondary, .nav-cta, .service-card, .pricing-card, .work-card, .feature-card, .process-grid article, .preview, .contact-card")
          .forEach((el) => {
            let frame = 0;
            const strength = el.matches(".btn-primary, .btn-secondary, .nav-cta") ? 0.12 : 0.035;

            el.addEventListener("mousemove", (event) => {
              const pointer = event;
              window.cancelAnimationFrame(frame);
              frame = window.requestAnimationFrame(() => {
                const rect = el.getBoundingClientRect();
                const x = (pointer.clientX - (rect.left + rect.width / 2)) * strength;
                const y = (pointer.clientY - (rect.top + rect.height / 2)) * strength;
                el.style.setProperty("--hover-x", `${x.toFixed(2)}px`);
                el.style.setProperty("--hover-y", `${y.toFixed(2)}px`);
              });
            });

            el.addEventListener("mouseleave", () => {
              window.cancelAnimationFrame(frame);
              el.style.setProperty("--hover-x", "0px");
              el.style.setProperty("--hover-y", "0px");
            });
          });
      }
    </script>
  </body>
</html>
