---
import "../index.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { siteUrl } from "../data/seo-pages";

const canonical = `${siteUrl}/hiring`;
const pageTitle = "Open Recruitment Solivate Studio | Join Our Digital Team";
const pageDescription =
  "Open recruitment Solivate Studio untuk Web Developer, Data Analyst, Finance, Marketing SEO Ads, Content Creator, Customer Relations, Database Architecture, dan Deploy Specialist.";

const positions = [
  ["01", "hiring.pos.1.title", "hiring.pos.1.desc"],
  ["02", "hiring.pos.2.title", "hiring.pos.2.desc"],
  ["03", "hiring.pos.3.title", "hiring.pos.3.desc"],
  ["04", "hiring.pos.4.title", "hiring.pos.4.desc"],
  ["05", "hiring.pos.5.title", "hiring.pos.5.desc"],
  ["06", "hiring.pos.6.title", "hiring.pos.6.desc"],
  ["07", "hiring.pos.7.title", "hiring.pos.7.desc"],
  ["08", "hiring.pos.8.title", "hiring.pos.8.desc"]
];

const benefits = [
  ["BR", "hiring.why.1.title", "hiring.why.1.desc"],
  ["PR", "hiring.why.2.title", "hiring.why.2.desc"],
  ["FX", "hiring.why.3.title", "hiring.why.3.desc"]
];

const staticI18n = {
  "nav.about": { id: "Tentang", en: "About" },
  "nav.services": { id: "Layanan", en: "Services" },
  "nav.pricing": { id: "Harga", en: "Pricing" },
  "nav.work": { id: "Karya", en: "Work" },
  "nav.process": { id: "Proses", en: "Process" },
  "nav.contact": { id: "Kontak", en: "Contact" },
  "nav.cta": { id: "Mulai Proyek", en: "Start Project" },
  "hiring.eyebrow": { id: "Open Recruitment", en: "Open Recruitment" },
  "hiring.title": { id: "Gabung tim digital yang lagi bertumbuh.", en: "Join a growing digital team." },
  "hiring.lead": {
    id: "Solivate Studio membuka kesempatan untuk talenta yang ingin belajar, membangun project nyata, dan ikut membawa UMKM, komunitas, event, serta brand lokal naik kelas secara digital.",
    en: "Solivate Studio is opening opportunities for talents who want to learn, build real projects, and help SMEs, communities, events, and local brands level up digitally."
  },
  "hiring.primary": { id: "Daftar Sekarang", en: "Apply Now" },
  "hiring.secondary": { id: "Lihat Posisi", en: "View Positions" },
  "hiring.panel.1": { id: "8 posisi dibuka", en: "8 open roles" },
  "hiring.panel.2": { id: "Project nyata", en: "Real projects" },
  "hiring.panel.3": { id: "Belajar bareng tim", en: "Grow with the team" },
  "hiring.positions_eyebrow": { id: "Posisi Dibuka", en: "Open Roles" },
  "hiring.positions_title": { id: "Pilih role yang paling dekat dengan skill dan minat kamu.", en: "Choose the role closest to your skills and interests." },
  "hiring.positions_subtitle": {
    id: "Tidak harus expert dari awal. Yang penting punya dasar, rasa ingin belajar, komunikasi jelas, dan komitmen untuk kontribusi nyata.",
    en: "You do not need to be an expert from day one. What matters is fundamentals, willingness to learn, clear communication, and real contribution."
  },
  "hiring.pos.1.title": { id: "Web Dev Frontend & Backend", en: "Frontend & Backend Web Dev" },
  "hiring.pos.1.desc": { id: "Membangun UI responsif, integrasi API, logic backend, dan pengalaman web yang cepat serta mudah digunakan.", en: "Build responsive UI, API integrations, backend logic, and fast, easy-to-use web experiences." },
  "hiring.pos.2.title": { id: "Data Analyst & Finance Analyst", en: "Data Analyst & Finance Analyst" },
  "hiring.pos.2.desc": { id: "Membaca data performa, menyusun insight, dan membantu perencanaan finansial project secara lebih rapi.", en: "Read performance data, shape insights, and support cleaner project financial planning." },
  "hiring.pos.3.title": { id: "Finance", en: "Finance" },
  "hiring.pos.3.desc": { id: "Mengelola administrasi keuangan, arus kas, invoice, pencatatan, dan kebutuhan operasional finansial.", en: "Manage financial administration, cash flow, invoices, records, and operational finance needs." },
  "hiring.pos.4.title": { id: "Marketing & SEO/Ads Optimization", en: "Marketing & SEO/Ads Optimization" },
  "hiring.pos.4.desc": { id: "Merancang campaign, optimasi SEO, iklan digital, dan strategi akuisisi yang relevan untuk target pasar.", en: "Design campaigns, optimize SEO, manage digital ads, and build acquisition strategies for target markets." },
  "hiring.pos.5.title": { id: "Content Creator Instagram/TikTok", en: "Instagram/TikTok Content Creator" },
  "hiring.pos.5.desc": { id: "Membuat ide konten, script pendek, visual, dan video yang membantu brand Solivate terasa lebih hidup.", en: "Create content ideas, short scripts, visuals, and videos that make Solivate's brand feel more alive." },
  "hiring.pos.6.title": { id: "Customer Relations", en: "Customer Relations" },
  "hiring.pos.6.desc": { id: "Menjaga komunikasi dengan klien, merapikan kebutuhan, dan memastikan update project mudah dipahami.", en: "Maintain client communication, organize requirements, and make project updates easy to understand." },
  "hiring.pos.7.title": { id: "Database Architecture", en: "Database Architecture" },
  "hiring.pos.7.desc": { id: "Mendesain struktur database yang aman, efisien, mudah dikembangkan, dan sesuai kebutuhan produk.", en: "Design secure, efficient, scalable database structures aligned with product needs." },
  "hiring.pos.8.title": { id: "Deploy Specialist", en: "Deploy Specialist" },
  "hiring.pos.8.desc": { id: "Mengelola deployment, environment, domain, hosting, CI/CD, dan stabilitas rilis project.", en: "Manage deployments, environments, domains, hosting, CI/CD, and release stability." },
  "hiring.why_eyebrow": { id: "Kenapa Solivate", en: "Why Solivate" },
  "hiring.why_title": { id: "Tempat buat belajar sambil benar-benar membangun.", en: "A place to learn while actually building." },
  "hiring.why.1.title": { id: "Belajar & berkembang", en: "Learn & grow" },
  "hiring.why.1.desc": { id: "Kamu akan ikut proses project dari ide, desain, development, sampai rilis sehingga skill bertumbuh lewat praktik.", en: "You will join the project process from idea, design, development, to launch so your skills grow through practice." },
  "hiring.why.2.title": { id: "Project nyata", en: "Real projects" },
  "hiring.why.2.desc": { id: "Portofolio kamu akan diisi oleh pekerjaan nyata untuk UMKM, komunitas, event, dan brand yang benar-benar digunakan.", en: "Your portfolio will include real work for SMEs, communities, events, and brands that are actually used." },
  "hiring.why.3.title": { id: "Fleksibel & suportif", en: "Flexible & supportive" },
  "hiring.why.3.desc": { id: "Kami menjaga ritme kerja tetap adaptif, komunikatif, dan terbuka untuk proses belajar yang sehat.", en: "We keep the work rhythm adaptive, communicative, and open to a healthy learning process." },
  "hiring.who_eyebrow": { id: "Siap daftar?", en: "Ready to apply?" },
  "hiring.who_title": { id: "Kirim data, portfolio, dan alasan kamu ingin bergabung.", en: "Send your details, portfolio, and reason to join." },
  "hiring.who_desc": { id: "Form pendaftaran singkat. Tim Solivate akan review dan menghubungi kandidat yang cocok lewat WhatsApp atau email.", en: "A short application form. Solivate will review and contact suitable candidates via WhatsApp or email." },
  "hiring.cta_btn": { id: "Isi Formulir Pendaftaran", en: "Fill Application Form" },
  "footer.title": { id: "Bangun sesuatu yang orang ingat.", en: "Let's build something people remember." },
  "footer.cta": { id: "Mulai Proyek", en: "Start Project" },
  "footer.desc": {
    id: "Digital solution provider untuk UMKM, komunitas sosial, event, celebration, dan sistem custom yang ingin naik kelas secara digital.",
    en: "Digital solution provider for SMEs, social communities, events, celebrations, and custom systems ready to level up digitally."
  },
  "footer.nav": { id: "Navigasi", en: "Navigation" },
  "footer.connect": { id: "Kontak", en: "Connect" },
  "footer.copy": { id: `Copyright ${new Date().getFullYear()} Solivate Studio. Semua hak dilindungi.`, en: `Copyright ${new Date().getFullYear()} Solivate Studio. All rights reserved.` },
  "footer.top": { id: "Kembali ke atas", en: "Back to top" },
  "floating.wa": { id: "Konsultasi sekarang, gratis!", en: "Free consultation now!" }
};

const i18nJson = JSON.stringify(staticI18n);
const initialText = (key: string) => staticI18n[key as keyof typeof staticI18n]?.id ?? key;
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  name: pageTitle,
  url: canonical,
  description: pageDescription,
  publisher: {
    "@type": "Organization",
    name: "Solivate Studio",
    url: siteUrl,
    logo: `${siteUrl}/solivate-logo.webp`
  }
});
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content="open recruitment Solivate Studio, lowongan web developer, lowongan digital marketing, lowongan content creator, lowongan database architecture, lowongan deploy specialist" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Solivate Studio" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${siteUrl}/solivate-logo.webp`} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body>
    <Header compact i18n />

    <main class="hiring-page">
      <section class="hiring-hero">
        <div class="hero-bg"></div>
        <div class="container hiring-hero-grid">
          <div class="hiring-hero-copy">
            <p class="eyebrow" data-i18n="hiring.eyebrow">{initialText("hiring.eyebrow")}</p>
            <h1 data-i18n="hiring.title">{initialText("hiring.title")}</h1>
            <p class="hero-text" data-i18n="hiring.lead">{initialText("hiring.lead")}</p>
            <div class="hero-actions">
              <a class="btn-primary" href="/hiring/apply">
                <span data-i18n="hiring.primary">{initialText("hiring.primary")}</span>
                <svg class="arrow" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg>
              </a>
              <a class="btn-secondary" href="#roles" data-i18n="hiring.secondary">{initialText("hiring.secondary")}</a>
            </div>
          </div>
          <div class="hiring-status-panel">
            <div>
              <strong>08</strong>
              <span data-i18n="hiring.panel.1">{initialText("hiring.panel.1")}</span>
            </div>
            <div>
              <strong>Live</strong>
              <span data-i18n="hiring.panel.2">{initialText("hiring.panel.2")}</span>
            </div>
            <div>
              <strong>Team</strong>
              <span data-i18n="hiring.panel.3">{initialText("hiring.panel.3")}</span>
            </div>
          </div>
        </div>
      </section>

      <section id="roles" class="section hiring-roles-section">
        <div class="container section-head split">
          <div>
            <p class="eyebrow" data-i18n="hiring.positions_eyebrow">{initialText("hiring.positions_eyebrow")}</p>
            <h2 data-i18n="hiring.positions_title">{initialText("hiring.positions_title")}</h2>
          </div>
          <p class="lead" data-i18n="hiring.positions_subtitle">{initialText("hiring.positions_subtitle")}</p>
        </div>
        <div class="container hiring-role-grid">
          {positions.map(([code, titleKey, descKey]) => (
            <article class="hiring-role-card">
              <span>{code}</span>
              <h3 data-i18n={titleKey}>{initialText(titleKey)}</h3>
              <p data-i18n={descKey}>{initialText(descKey)}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section hiring-benefit-section">
        <div class="container section-head">
          <p class="eyebrow" data-i18n="hiring.why_eyebrow">{initialText("hiring.why_eyebrow")}</p>
          <h2 data-i18n="hiring.why_title">{initialText("hiring.why_title")}</h2>
        </div>
        <div class="container hiring-benefit-grid">
          {benefits.map(([code, titleKey, descKey]) => (
            <article class="hiring-benefit-card">
              <span>{code}</span>
              <h3 data-i18n={titleKey}>{initialText(titleKey)}</h3>
              <p data-i18n={descKey}>{initialText(descKey)}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section hiring-cta-section">
        <div class="container hiring-cta-band">
          <p class="eyebrow" data-i18n="hiring.who_eyebrow">{initialText("hiring.who_eyebrow")}</p>
          <h2 data-i18n="hiring.who_title">{initialText("hiring.who_title")}</h2>
          <p data-i18n="hiring.who_desc">{initialText("hiring.who_desc")}</p>
          <a href="/hiring/apply" class="btn-primary">
            <span data-i18n="hiring.cta_btn">{initialText("hiring.cta_btn")}</span>
            <svg class="arrow" aria-hidden="true" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17L17 7"></path><path d="M7 7h10v10"></path></svg>
          </a>
        </div>
      </section>
    </main>

    <Footer i18n />
    <script is:inline type="application/ld+json" set:html={schema}></script>
    <script is:inline type="application/json" id="hiring-i18n-data" set:html={i18nJson}></script>
    <script is:inline>
      const translations = JSON.parse(document.getElementById("hiring-i18n-data")?.textContent || "{}");
      const header = document.querySelector("[data-header]");
      const updateHeader = () => {
        const y = Math.max(0, window.scrollY);
        header?.classList.toggle("is-scrolled", y > 24);
        header?.classList.toggle("is-compact", y > 64);
      };
      window.addEventListener("scroll", updateHeader, { passive: true });
      updateHeader();

      document.querySelectorAll("[data-top]").forEach((trigger) => {
        trigger.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
      });
      document.querySelectorAll("[data-home-contact]").forEach((trigger) => {
        trigger.addEventListener("click", () => {
          window.location.href = "/#contact";
        });
      });

      const setLanguage = (lang, persist = false) => {
        const activeLang = lang === "en" ? "en" : "id";
        document.documentElement.lang = activeLang;
        if (persist) {
          window.localStorage.setItem("solivate-language", activeLang);
          window.localStorage.setItem("solivate-language-manual", "true");
        }

        document.querySelectorAll("[data-i18n]").forEach((node) => {
          const key = node.getAttribute("data-i18n");
          const next = translations[key]?.[activeLang];
          if (next) node.textContent = next;
        });

        document.querySelectorAll("[data-lang-switch]").forEach((button) => {
          const active = button.getAttribute("data-lang-switch") === activeLang;
          button.classList.toggle("active", active);
          button.setAttribute("aria-pressed", String(active));
        });
      };

      document.querySelectorAll("[data-lang-switch]").forEach((button) => {
        button.addEventListener("click", () => setLanguage(button.getAttribute("data-lang-switch"), true));
      });
      const savedLanguage = window.localStorage.getItem("solivate-language-manual") === "true"
        ? window.localStorage.getItem("solivate-language")
        : "id";
      setLanguage(savedLanguage || "id");
    </script>
  </body>
</html>
