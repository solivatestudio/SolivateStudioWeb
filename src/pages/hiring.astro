---
import "../index.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { siteUrl } from "../data/seo-pages";

const canonical = `${siteUrl}/hiring`;
const pageTitle = "Open Recruitment | Solivate Studio";
const pageDescription = "Gabung bersama Solivate Studio dan bertumbuh bareng tim solid untuk membangun project digital berkualitas.";

const staticI18n = {
  "nav.about": { id: "Tentang", en: "About" },
  "nav.services": { id: "Layanan", en: "Services" },
  "nav.pricing": { id: "Harga", en: "Pricing" },
  "nav.work": { id: "Karya", en: "Work" },
  "nav.process": { id: "Proses", en: "Process" },
  "nav.contact": { id: "Kontak", en: "Contact" },
  "nav.cta": { id: "Mulai Proyek", en: "Start Project" },
  
  // Hero
  "hiring.eyebrow": { id: "Open Recruitment", en: "Open Recruitment" },
  "hiring.title": { id: "Bergabung & Bertumbuh Bersama Solivate", en: "Join & Grow Together with Solivate" },
  "hiring.lead": { 
    id: "Solivate Studio lagi cari talenta-talenta baru buat gabung dan bertumbuh bareng! Kalau lo punya skill, passion, dan semangat buat berkarya, ini saatnya gabung tim kami.", 
