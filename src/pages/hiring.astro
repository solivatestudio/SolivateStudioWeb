  },

  // Positions
  "hiring.positions_title": { id: "Posisi yang Dibuka", en: "Open Positions" },
  "hiring.positions_subtitle": { id: "Temukan peran yang sesuai dengan minat dan keahlianmu.", en: "Find a role that matches your interests and skills." },
  
  "hiring.pos.1.title": { id: "Web Dev (Frontend & Backend)", en: "Web Dev (Frontend & Backend)" },
  "hiring.pos.1.desc": { id: "Membangun antarmuka web yang responsif atau mengelola logika server dan database.", en: "Building responsive web interfaces or managing server logic and databases." },
  
  "hiring.pos.2.title": { id: "Data Analyst & Finance Analyst", en: "Data Analyst & Finance Analyst" },
  "hiring.pos.2.desc": { id: "Menganalisis data performa bisnis dan membantu perencanaan finansial proyek.", en: "Analyzing business performance data and assisting in project financial planning." },
  
  "hiring.pos.3.title": { id: "Finance", en: "Finance" },
  "hiring.pos.3.desc": { id: "Mengelola administrasi keuangan, arus kas, dan invoicing klien.", en: "Managing financial administration, cash flows, and client invoicing." },
  
  "hiring.pos.4.title": { id: "Marketing & SEO/Ads Optimization", en: "Marketing & SEO/Ads Optimization" },
  "hiring.pos.4.desc": { id: "Merancang strategi pemasaran, optimasi mesin pencari, dan kampanye iklan digital.", en: "Designing marketing strategies, search engine optimization, and digital ad campaigns." },
  
  "hiring.pos.5.title": { id: "Content Creator (Instagram/TikTok)", en: "Content Creator (Instagram/TikTok)" },
  "hiring.pos.5.desc": { id: "Membuat konten visual dan video kreatif untuk meningkatkan engagement di media sosial.", en: "Creating creative visual and video content to increase engagement on social media." },
  
  "hiring.pos.6.title": { id: "Customer Relations", en: "Customer Relations" },
  "hiring.pos.6.desc": { id: "Menjembatani komunikasi dengan klien dan memastikan kebutuhan mereka terpenuhi dengan baik.", en: "Bridging communication with clients and ensuring their needs are well met." },
  
  "hiring.pos.7.title": { id: "Database Architecture", en: "Database Architecture" },
  "hiring.pos.7.desc": { id: "Merancang struktur database yang efisien, aman, dan mudah diskalakan.", en: "Designing database structures that are efficient, secure, and scalable." },
  
  "hiring.pos.8.title": { id: "Deploy Specialist", en: "Deploy Specialist" },
  "hiring.pos.8.desc": { id: "Mengelola deployment aplikasi, konfigurasi server, dan alur CI/CD otomatis.", en: "Managing application deployment, server configurations, and automated CI/CD pipelines." },

  // Why
  "hiring.why_title": { id: "Kenapa Join Solivate Studio?", en: "Why Join Solivate Studio?" },
  "hiring.why.1.title": { id: "Belajar & Berkembang", en: "Learn & Grow" },
  "hiring.why.1.desc": { id: "Bertumbuh bersama tim yang solid dan suportif untuk meningkatkan skill-mu secara langsung.", en: "Grow together with a solid and supportive team to elevate your skills directly." },
  "hiring.why.2.title": { id: "Project Nyata, Pengalaman Nyata", en: "Real Projects, Real Experience" },
  "hiring.why.2.desc": { id: "Dapatkan portofolio nyata dengan menangani project aktif dari berbagai industri klien.", en: "Get a real-world portfolio by handling active projects from various client industries." },
  "hiring.why.3.title": { id: "Lingkungan Kerja Suportif & Fleksibel", en: "Supportive & Flexible Environment" },
  "hiring.why.3.desc": { id: "Nikmati lingkungan kerja yang adaptif, menghargai kreativitas, dan fleksibel.", en: "Enjoy a work environment that is adaptive, values creativity, and is flexible." },

  // Who & CTA
  "hiring.who_title": { id: "Siapa Aja Boleh Daftar!", en: "Anyone Can Apply!" },
  "hiring.who_desc": { 
    id: "Punya minat di salah satu bidang di atas? Gak perlu expert, yang penting niat belajar dan kontribusi nyata!", 
    en: "Interested in one of the fields above? No need to be an expert, what matters is your willingness to learn and make a real contribution!" 
  },
  "hiring.cta_btn": { id: "Isi Formulir Pendaftaran Sekarang", en: "Fill the Recruitment Form Now" },

  // Footer & Misc
  "footer.title": { id: "Bangun sesuatu yang orang ingat.", en: "Let's build something people remember." },
  "footer.cta": { id: "Mulai Proyek", en: "Start Project" },
  "footer.desc": {
    id: "Digital solution provider untuk UMKM, komunitas sosial, event, celebration, dan sistem custom yang ingin naik kelas secara digital.",
    en: "Digital solution provider for SMEs, social communities, events, celebrations, and custom systems ready to level up digitally."
  },
  "footer.nav": { id: "Navigasi", en: "Navigation" },
  "footer.connect": { id: "Kontak", en: "Connect" },
  "footer.legal": { id: "Kebijakan", en: "Policies" },
  "footer.privacy": { id: "Kebijakan Privasi", en: "Privacy Policy" },
  "footer.terms": { id: "Syarat & Ketentuan", en: "Terms & Conditions" },
  "footer.revision": { id: "Kebijakan Revisi", en: "Revision Policy" },
  "footer.copy": { id: `Copyright ${new Date().getFullYear()} Solivate Studio. Semua hak dilindungi.`, en: `Copyright ${new Date().getFullYear()} Solivate Studio. All rights reserved.` },
  "footer.top": { id: "Kembali ke atas", en: "Back to top" },
