# RESEND_API_KEY: Required for contact form email delivery.
# Configure this in Vercel Project Settings > Environment Variables.
RESEND_API_KEY="re_xxxxxxxxx"
RESEND_TO_EMAIL="solivatestudio@gmail.com"
RESEND_FROM_EMAIL="Solivate Studio <onboarding@resend.dev>"

# Cloudflare Turnstile anti-bot protection for contact and hiring forms.
PUBLIC_TURNSTILE_SITE_KEY="0x4AAAA_example_site_key"
TURNSTILE_SECRET_KEY="0x4AAAA_example_secret_key"

# Neon Postgres connection string for CMS, operations, and analytics.
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"

# UploadThing token for dashboard image and document uploads.
UPLOADTHING_TOKEN="sk_live_xxxxxxxxx"

# Single-admin dashboard authentication.
ADMIN_USERNAME="admin"
# Generate with: npm run admin:hash -- "your-password"
ADMIN_PASSWORD_HASH="scrypt:replace_with_generated_hash"
SESSION_SECRET="replace_with_a_long_random_string"
TRACKING_SALT="replace_with_another_long_random_string"
